@model Sofranet.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Kayıt Ol";
    ViewData["BodyClass"] = "auth-page";
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4 p-md-5">
                <div class="text-center mb-4">
                    <h2 class="fw-bold mb-1">Sofranet'e katıl</h2>
                    <p class="text-muted">Hesabını oluştur, sipariş vermeye başla</p>
                </div>

                <form asp-action="Register" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small d-none-if-empty"></div>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label"></label>
                        <input asp-for="FullName" class="form-control" placeholder="Adın Soyadın" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" placeholder="ornek@mail.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Phone" class="form-label"></label>
                        <input asp-for="Phone" class="form-control" placeholder="05xx..." />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Password" class="form-label"></label>
                            <input asp-for="Password" class="form-control" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="ConfirmPassword" class="form-label"></label>
                            <input asp-for="ConfirmPassword" class="form-control" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label d-block">Hesap Tipi</label>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" asp-for="Role" value="User" id="roleUser" />
                            <label class="form-check-label" for="roleUser">Müşteri</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" asp-for="Role" value="Caterer" id="roleCaterer" />
                            <label class="form-check-label" for="roleCaterer">Restoran (Caterer)</label>
                        </div>
                        <span asp-validation-for="Role" class="text-danger small d-block"></span>
                    </div>

                    <div class="mb-3" id="addressGroup" style="display:none;">
                        <label asp-for="Address" class="form-label">Restoran Adresi</label>
                        <textarea asp-for="Address" class="form-control" rows="2"
                                  placeholder="Tam adres - mahalleler ve sokak adı"></textarea>
                        <small class="text-muted">Caterer için zorunlu. Adresten konum otomatik bulunmaya çalışılır.</small>
                        <span asp-validation-for="Address" class="text-danger small d-block"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2">Kayıt Ol</button>
                </form>

                <hr class="my-4" />
                <p class="text-center mb-0 text-muted small">
                    Zaten hesabın var mı?
                    <a asp-action="Login">Giriş yap</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    (function () {
        function toggleAddress() {
            var caterer = document.getElementById('roleCaterer');
            var grp = document.getElementById('addressGroup');
            grp.style.display = (caterer && caterer.checked) ? 'block' : 'none';
        }
        document.querySelectorAll('input[name="Role"]').forEach(function (el) {
            el.addEventListener('change', toggleAddress);
        });
        toggleAddress();
    })();
</script>
}
