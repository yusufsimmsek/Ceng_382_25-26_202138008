@model Sofranet.Models.ViewModels.MenuDetailViewModel
@{
    ViewData["Title"] = Model.Item.Name;
    var item = Model.Item;
}

@functions {
    string Stars(decimal? avg)
    {
        if (!avg.HasValue) return string.Empty;
        int filled = (int)Math.Floor(avg.Value);
        if (filled < 0) filled = 0;
        if (filled > 5) filled = 5;
        return new string('★', filled) + new string('☆', 5 - filled);
    }
}

<a asp-action="Index" class="text-muted text-decoration-none small">← Menülere dön</a>

<div class="row mt-3">
    <div class="col-md-6 mb-4">
        <img src="@(item.ImagePath ?? "/images/no-image.svg")" class="menu-detail-image" alt="@item.Name" />
    </div>
    <div class="col-md-6">
        <h2 class="mb-1">@item.Name</h2>
        <div class="text-muted">@Model.CatererName</div>
        @if (!string.IsNullOrWhiteSpace(Model.CatererAddress))
        {
            <div class="text-muted small">@Model.CatererAddress</div>
        }

        <div class="mt-2">
            @if (Model.MenuAvg.HasValue)
            {
                <div>
                    <span class="rating-stars">@Stars(Model.MenuAvg)</span>
                    <strong class="ms-1">@Model.MenuAvg.Value.ToString("0.0")</strong>
                    <small class="text-muted">(@Model.RatingCount değerlendirme)</small>
                </div>
            }
            else
            {
                <small class="text-muted">Henüz değerlendirme yok</small>
            }
            @if (Model.CatererAvg.HasValue)
            {
                <small class="text-muted d-block">
                    Restoran puanı: <span class="rating-stars">★</span> @Model.CatererAvg.Value.ToString("0.0")
                </small>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(item.Description))
        {
            <p class="mt-3">@item.Description</p>
        }

        <div class="detail-price mt-3">₺@item.Price.ToString("0.00")</div>
    </div>
</div>

<hr class="my-4" />

<form method="post" action="/Cart/Add" id="orderForm" data-base-price="@item.Price.ToString(System.Globalization.CultureInfo.InvariantCulture)">
    @Html.AntiForgeryToken()
    <input type="hidden" name="menuItemId" value="@item.Id" />

    <h3 class="mb-3">Siparişini Özelleştir</h3>

    @foreach (var group in Model.Groups)
    {
        <div class="option-section">
            <h5>
                @group.Name
                @if (group.IsRequired)
                {
                    <span class="badge bg-danger ms-1">Zorunlu</span>
                }
            </h5>
            <small class="text-muted d-block mb-2">
                (en az @group.MinSelect, en fazla @group.MaxSelect seçim)
            </small>

            @if (group.MaxSelect == 1)
            {
                @* Radio buttons *@
                @foreach (var opt in group.Options.OrderBy(o => o.Id))
                {
                    <div class="form-check option-row">
                        <div>
                            <input class="form-check-input" type="radio"
                                   name="options_@group.Id"
                                   value="@opt.Id"
                                   id="opt_@opt.Id"
                                   data-extra-price="@opt.ExtraPrice.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                   @(group.IsRequired ? "required" : "") />
                            <label class="form-check-label" for="opt_@opt.Id">@opt.Name</label>
                        </div>
                        @if (opt.ExtraPrice > 0)
                        {
                            <span class="option-extra">+₺@opt.ExtraPrice.ToString("0.00")</span>
                        }
                    </div>
                }
            }
            else
            {
                @* Checkboxes *@
                @foreach (var opt in group.Options.OrderBy(o => o.Id))
                {
                    <div class="form-check option-row">
                        <div>
                            <input class="form-check-input" type="checkbox"
                                   name="options"
                                   value="@opt.Id"
                                   id="opt_@opt.Id"
                                   data-extra-price="@opt.ExtraPrice.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                   data-group-id="@group.Id"
                                   data-max="@group.MaxSelect" />
                            <label class="form-check-label" for="opt_@opt.Id">@opt.Name</label>
                        </div>
                        @if (opt.ExtraPrice > 0)
                        {
                            <span class="option-extra">+₺@opt.ExtraPrice.ToString("0.00")</span>
                        }
                    </div>
                }
            }
        </div>
    }

    @if (Model.Removables.Any())
    {
        <div class="option-section">
            <h5>Çıkarmak istediklerini seç</h5>
            <small class="text-muted d-block mb-2">İşaretlediklerin yemekten çıkartılır.</small>
            @foreach (var r in Model.Removables)
            {
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="removals" value="@r.Id" id="rem_@r.Id" />
                    <label class="form-check-label" for="rem_@r.Id">@r.Name</label>
                </div>
            }
        </div>
    }

    <div class="option-section">
        <h5>Adet</h5>
        <div class="qty-controls">
            <button type="button" class="qty-btn" data-action="decrease">−</button>
            <input type="number" name="quantity" id="qtyInput" value="1" min="1" max="20"
                   class="form-control" style="width:80px;text-align:center;" />
            <button type="button" class="qty-btn" data-action="increase">+</button>
        </div>
    </div>

    <div class="total-display">
        Toplam: ₺<span id="totalPrice">@item.Price.ToString("0.00")</span>
    </div>

    <button type="submit" class="btn btn-primary btn-lg w-100">Sepete Ekle</button>
</form>

<hr class="my-4" />

<section>
    <h4 class="mb-3">Son Yorumlar</h4>
    @if (Model.RecentComments.Any())
    {
        foreach (var c in Model.RecentComments)
        {
            <div class="comment-card">
                <div class="comment-meta d-flex justify-content-between">
                    <span><strong>@c.UserName</strong></span>
                    <small>@c.CreatedAt.ToString("dd.MM.yyyy")</small>
                </div>
                <div class="rating-stars">@Stars(c.MenuRating)</div>
                <p class="mb-0 mt-1">@c.Comment</p>
            </div>
        }
    }
    else
    {
        <p class="text-muted">Henüz yorum yok.</p>
    }
</section>

<hr class="my-4" />

<section>
    <h4 class="mb-3">Restoran Konumu</h4>
    @if (Model.CatererLat.HasValue && Model.CatererLng.HasValue)
    {
        <div id="menuDetailMap"
             style="width:100%;height:280px;border-radius:8px;"
             data-lat="@Model.CatererLat.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)"
             data-lng="@Model.CatererLng.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)"
             data-name="@Model.CatererName"></div>
    }
    else
    {
        <div class="text-muted"><small>Bu restoranın konum bilgisi henüz yok.</small></div>
    }
</section>

@section Scripts {
    <script src="~/js/menu-detail.js" asp-append-version="true"></script>
    @{ var mapsKey = ViewBag.GoogleMapsKey as string; }
    @if (Model.CatererLat.HasValue && Model.CatererLng.HasValue)
    {
        if (!string.IsNullOrEmpty(mapsKey))
        {
            <script src="~/js/maps.js" asp-append-version="true"></script>
            <script async defer src="https://maps.googleapis.com/maps/api/js?key=@mapsKey&callback=initMaps"></script>
        }
        else
        {
            <script>window.GMAPS_DISABLED = true;</script>
            <script src="~/js/maps.js" asp-append-version="true"></script>
        }
    }
}
