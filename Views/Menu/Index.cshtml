@model List<Sofranet.Models.ViewModels.MenuListItemViewModel>
@{
    ViewData["Title"] = "Menüler";
    var caterers = ViewBag.Caterers as IEnumerable<dynamic>;
    var selectedCaterer = ViewBag.SelectedCaterer as string;
    var minPrice = ViewBag.MinPrice as decimal?;
    var maxPrice = ViewBag.MaxPrice as decimal?;
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
    var total = (int)(ViewBag.Total ?? 0);

    var isUserRole = (bool)(ViewBag.IsUserRole ?? false);
    var locationAvailable = (bool)(ViewBag.LocationAvailable ?? false);
    var radiusVal = (int)(ViewBag.Radius ?? 10);
    var distances = (Dictionary<string, double>)(ViewBag.CatererDistances ?? new Dictionary<string, double>());
    var needsMaps = (bool)(ViewBag.NeedsMaps ?? false);
    var mapsKey = ViewBag.GoogleMapsKey as string;
}

@functions {
    string Stars(decimal? avg)
    {
        if (!avg.HasValue) return string.Empty;
        int filled = (int)Math.Floor(avg.Value);
        if (filled < 0) filled = 0;
        if (filled > 5) filled = 5;
        return new string('★', filled) + new string('☆', 5 - filled);
    }
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0">Menüler</h2>
        <small class="text-muted">@total ürün</small>
    </div>
</div>

@if (isUserRole)
{
    if (!locationAvailable)
    {
        <div class="location-banner-warn">
            <strong>📍 Konumun belirli değil</strong> — Yakındaki restoranları görmek için konumunu belirle.
            <form method="post" asp-controller="Account" asp-action="UpdateLocation" class="d-inline" id="quickLocateForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="latitude" id="quickLat" />
                <input type="hidden" name="longitude" id="quickLng" />
                <input type="hidden" name="returnUrl" value="/Menu" />
                <button type="button" id="quickLocateBtn" class="btn btn-warning btn-sm ms-2">Konumumu Belirle</button>
            </form>
        </div>
    }
    else
    {
        <div class="location-banner-ok">
            <strong>✓ Konumun belirli</strong> — yakındaki restoranlar gösteriliyor.
            <form method="get" class="d-inline ms-2">
                <input type="hidden" name="caterer" value="@selectedCaterer" />
                <input type="hidden" name="minPrice" value="@(minPrice?.ToString("0.##"))" />
                <input type="hidden" name="maxPrice" value="@(maxPrice?.ToString("0.##"))" />
                <label class="me-1">Yarıçap:</label>
                <select name="radius" onchange="this.form.submit()" class="form-select form-select-sm d-inline-block" style="width:auto;">
                    <option value="5" selected="@(radiusVal == 5)">5 km</option>
                    <option value="10" selected="@(radiusVal == 10)">10 km</option>
                    <option value="20" selected="@(radiusVal == 20)">20 km</option>
                    <option value="50" selected="@(radiusVal == 50)">50 km</option>
                </select>
            </form>
            <a href="/Account/Profile" class="ms-2 small">Konumu güncelle</a>
        </div>
    }
}

<div class="filter-bar">
    <form method="get" asp-action="Index" class="row g-2 align-items-end">
        <input type="hidden" name="radius" value="@radiusVal" />
        <div class="col-md-4">
            <label class="form-label small mb-1">Restoran</label>
            <select name="caterer" class="form-select">
                <option value="">Tümü</option>
                @if (caterers != null)
                {
                    foreach (var c in caterers)
                    {
                        string cid = c.Id;
                        string cname = c.FullName;
                        <option value="@cid" selected="@(cid == selectedCaterer)">@cname</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small mb-1">Min Fiyat (₺)</label>
            <input type="number" name="minPrice" step="0.01" min="0" class="form-control"
                   value="@(minPrice?.ToString("0.##"))" />
        </div>
        <div class="col-md-3">
            <label class="form-label small mb-1">Max Fiyat (₺)</label>
            <input type="number" name="maxPrice" step="0.01" min="0" class="form-control"
                   value="@(maxPrice?.ToString("0.##"))" />
        </div>
        <div class="col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-primary flex-grow-1">Filtrele</button>
            <a asp-action="Index" class="btn btn-link text-muted px-2">Temizle</a>
        </div>
    </form>
</div>

@if (needsMaps)
{
    <div class="mb-3">
        <button class="btn btn-outline-primary" type="button" data-bs-toggle="collapse"
                data-bs-target="#mapCollapse">
            🗺️ Haritada Göster
        </button>
    </div>
    <div class="collapse mb-3" id="mapCollapse">
        <div id="menuListMap"
             style="width:100%;height:400px;border-radius:8px;"
             data-user-lat="@(ViewBag.UserLat?.ToString(System.Globalization.CultureInfo.InvariantCulture))"
             data-user-lng="@(ViewBag.UserLng?.ToString(System.Globalization.CultureInfo.InvariantCulture))"
             data-caterers='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.MapCaterers))'></div>
    </div>
}

@if (Model.Count == 0)
{
    <div class="text-center py-5 text-muted">
        <div style="font-size:3rem;">🍽️</div>
        <p>
            @if (isUserRole && locationAvailable)
            {
                <text>Bu yarıçap içinde menü yok. Yarıçapı genişletmeyi dene.</text>
            }
            else
            {
                <text>Bu kriterlere uygun menü yok.</text>
            }
        </p>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var vm in Model)
        {
            var item = vm.Item;
            <div class="col-md-4 col-lg-3">
                <div class="card menu-card h-100">
                    <img src="@(item.ImagePath ?? "/images/no-image.svg")" class="menu-card-img" alt="@item.Name" />
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title mb-1">@item.Name</h5>
                        <div class="caterer-name">@vm.CatererName</div>

                        @if (distances.ContainsKey(item.CatererId))
                        {
                            <span class="distance-badge mt-1">📍 @distances[item.CatererId].ToString("0.0") km</span>
                        }

                        <div class="price my-2">₺@item.Price.ToString("0.00")</div>

                        @if (vm.MenuAvg.HasValue)
                        {
                            <div class="rating-stars">
                                <span>@Stars(vm.MenuAvg)</span>
                                <small class="text-muted">(@vm.RatingCount değerlendirme)</small>
                            </div>
                        }
                        else
                        {
                            <small class="text-muted">Henüz değerlendirme yok</small>
                        }

                        @if (vm.CatererAvg.HasValue)
                        {
                            <small class="text-muted mt-1">
                                Restoran: <span class="rating-stars">★</span> @vm.CatererAvg.Value.ToString("0.0")
                            </small>
                        }

                        @if (!string.IsNullOrWhiteSpace(item.Description))
                        {
                            <p class="text-muted small mt-2 mb-3">
                                @(item.Description.Length > 80 ? item.Description.Substring(0, 80) + "..." : item.Description)
                            </p>
                        }

                        <a asp-action="Detail" asp-route-id="@item.Id" class="btn btn-primary mt-auto">Detay</a>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (totalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center mb-0">
                @if (currentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index"
                           asp-route-caterer="@selectedCaterer"
                           asp-route-minPrice="@minPrice"
                           asp-route-maxPrice="@maxPrice"
                           asp-route-radius="@radiusVal"
                           asp-route-page="@(currentPage - 1)">Önceki</a>
                    </li>
                }
                <li class="page-item active"><span class="page-link">@(currentPage) / @totalPages</span></li>
                @if (currentPage < totalPages)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index"
                           asp-route-caterer="@selectedCaterer"
                           asp-route-minPrice="@minPrice"
                           asp-route-maxPrice="@maxPrice"
                           asp-route-radius="@radiusVal"
                           asp-route-page="@(currentPage + 1)">Sonraki</a>
                    </li>
                }
            </ul>
        </nav>
    }
}

@section Scripts {
    @if (needsMaps)
    {
        if (!string.IsNullOrEmpty(mapsKey))
        {
            <script src="~/js/maps.js" asp-append-version="true"></script>
            <script async defer src="https://maps.googleapis.com/maps/api/js?key=@mapsKey&callback=initMaps"></script>
        }
        else
        {
            <script>window.GMAPS_DISABLED = true;</script>
            <script src="~/js/maps.js" asp-append-version="true"></script>
        }
    }
    <script>
        (function () {
            var btn = document.getElementById('quickLocateBtn');
            if (!btn) return;
            btn.addEventListener('click', function () {
                if (!navigator.geolocation) {
                    alert('Tarayıcın konum desteklemiyor');
                    return;
                }
                btn.textContent = 'Alınıyor...';
                btn.disabled = true;
                navigator.geolocation.getCurrentPosition(
                    function (pos) {
                        document.getElementById('quickLat').value = pos.coords.latitude;
                        document.getElementById('quickLng').value = pos.coords.longitude;
                        document.getElementById('quickLocateForm').submit();
                    },
                    function (err) {
                        alert('Konum alınamadı: ' + err.message);
                        btn.textContent = 'Konumumu Belirle';
                        btn.disabled = false;
                    }
                );
            });
        })();
    </script>
}
