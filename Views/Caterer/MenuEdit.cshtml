@model Sofranet.Models.MenuItem
@{
    ViewData["Title"] = "Menü Düzenle";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="mb-0">Menü Düzenle</h2>
            <a asp-action="Menu" class="btn btn-link text-muted">← Listeye Dön</a>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-action="MenuEdit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" novalidate>
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small d-none-if-empty"></div>

                    <input type="hidden" asp-for="Id" />

                    @if (!string.IsNullOrWhiteSpace(Model.ImagePath))
                    {
                        <div class="mb-3">
                            <label class="form-label">Mevcut Görsel</label><br />
                            <img src="@Model.ImagePath" alt="" style="width:120px;height:120px;object-fit:cover;border-radius:8px;" />
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label">Görseli Değiştir (opsiyonel)</label>
                        <input type="file" name="image" accept="image/*" class="form-control" />
                        <small class="text-muted">Boş bırakırsan mevcut görsel kalır.</small>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">İsim</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Price" class="form-label">Fiyat (₺)</label>
                            <input asp-for="Price" type="number" step="0.01" min="0" class="form-control" />
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Durum</label>
                            <select asp-for="IsAvailable" class="form-select">
                                <option value="true">Aktif</option>
                                <option value="false">Pasif</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Açıklama</label>
                        <textarea asp-for="Description" rows="3" class="form-control"></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Güncelle</button>
                        <a asp-action="Menu" class="btn btn-outline-secondary">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
