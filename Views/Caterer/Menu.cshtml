@model List<Sofranet.Models.MenuItem>
@{
    ViewData["Title"] = "Menü Yönetimi";
    var query = ViewBag.Query as string;
    var currentPage = (int)(ViewBag.Page ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
    var total = (int)(ViewBag.Total ?? 0);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0">Menü Yönetimi</h2>
        <small class="text-muted">@total kayıt</small>
    </div>
    <a asp-action="MenuCreate" class="btn btn-primary">+ Yeni Menü Ekle</a>
</div>

<form method="get" class="d-flex gap-2 mb-3">
    <input type="text" name="q" value="@query" class="form-control" placeholder="Menü ismi ara..." style="max-width:340px;" />
    <button class="btn btn-outline-primary">Filtrele</button>
    @if (!string.IsNullOrWhiteSpace(query))
    {
        <a asp-action="Menu" class="btn btn-link text-muted">Temizle</a>
    }
</form>

@if (Model.Count == 0)
{
    <div class="text-center py-5 text-muted">
        <div style="font-size:3rem;">🍽️</div>
        <p class="mb-3">@(string.IsNullOrWhiteSpace(query) ? "Henüz menü eklemedin." : "Arama sonucu yok.")</p>
        @if (string.IsNullOrWhiteSpace(query))
        {
            <a asp-action="MenuCreate" class="btn btn-primary">İlk menünü ekle</a>
        }
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:60px;"></th>
                        <th>İsim</th>
                        <th style="width:120px;">Fiyat</th>
                        <th style="width:100px;">Durum</th>
                        <th style="width:280px;" class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    <tr class="@(item.IsAvailable ? "" : "table-secondary")">
                        <td>
                            <img src="@(item.ImagePath ?? "/images/no-image.svg")" class="menu-thumb" alt="" />
                        </td>
                        <td>
                            <div class="fw-semibold">@item.Name</div>
                            @if (!string.IsNullOrWhiteSpace(item.Description))
                            {
                                <small class="text-muted">@(item.Description.Length > 80 ? item.Description.Substring(0, 80) + "..." : item.Description)</small>
                            }
                        </td>
                        <td>₺@item.Price.ToString("0.00")</td>
                        <td>
                            @if (item.IsAvailable)
                            {
                                <span class="badge badge-active">Aktif</span>
                            }
                            else
                            {
                                <span class="badge badge-inactive">Pasif</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="MenuEdit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Düzenle</a>
                            <a asp-action="MenuCustomize" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Seçenekler</a>
                            @if (item.IsAvailable)
                            {
                                <form asp-action="MenuDelete" asp-route-id="@item.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Bu menüyü pasif yapmak istediğine emin misin?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Pasif Yap</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    @if (totalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center mb-0">
                @if (currentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Menu" asp-route-q="@query" asp-route-page="@(currentPage - 1)">Önceki</a>
                    </li>
                }
                <li class="page-item active"><span class="page-link">@(currentPage) / @totalPages</span></li>
                @if (currentPage < totalPages)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Menu" asp-route-q="@query" asp-route-page="@(currentPage + 1)">Sonraki</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
