@model List<Sofranet.Controllers.CatererOrderListItem>
@{
    ViewData["Title"] = "Gelen Siparişler";
    var currentStatus = ViewBag.Status as string;
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
    var total = (int)(ViewBag.Total ?? 0);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0">Gelen Siparişler</h2>
        <small class="text-muted">@total kayıt</small>
    </div>
</div>

<form method="get" class="mb-3 d-flex gap-2 align-items-center">
    <label class="small mb-0">Durum:</label>
    <select name="status" class="form-select form-select-sm d-inline-block" style="width:auto;"
            onchange="this.form.submit()">
        <option value="">Tümü</option>
        <option value="pending" selected="@(currentStatus == "pending")">Bekliyor</option>
        <option value="preparing" selected="@(currentStatus == "preparing")">Hazırlanıyor</option>
        <option value="completed" selected="@(currentStatus == "completed")">Tamamlandı</option>
        <option value="cancelled" selected="@(currentStatus == "cancelled")">İptal</option>
    </select>
    @if (!string.IsNullOrEmpty(currentStatus))
    {
        <a asp-action="Orders" class="btn btn-sm btn-link">Temizle</a>
    }
</form>

@if (Model.Count == 0)
{
    <div class="text-center py-5 text-muted">
        <div style="font-size:3rem;">📦</div>
        <p>Henüz sipariş yok</p>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Tarih</th>
                        <th>Müşteri</th>
                        <th>Ürün</th>
                        <th>Tutar</th>
                        <th>Durum</th>
                        <th class="text-end">PDF</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Model)
                    {
                        <tr>
                            <td>#@o.Id</td>
                            <td>@o.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                @o.UserName
                                <br /><small class="text-muted">@o.UserEmail</small>
                            </td>
                            <td>@o.ItemCount adet</td>
                            <td>₺@o.TotalAmount.ToString("0.00")</td>
                            <td>
                                <form asp-action="UpdateOrderStatus" method="post" class="d-inline" data-no-loading>
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@o.Id" />
                                    <select name="newStatus" onchange="this.form.submit()"
                                            class="form-select form-select-sm"
                                            style="width:auto;display:inline-block;">
                                        <option value="pending" selected="@(o.Status == "pending")">Bekliyor</option>
                                        <option value="preparing" selected="@(o.Status == "preparing")">Hazırlanıyor</option>
                                        <option value="completed" selected="@(o.Status == "completed")">Tamamlandı</option>
                                        <option value="cancelled" selected="@(o.Status == "cancelled")">İptal</option>
                                    </select>
                                </form>
                            </td>
                            <td class="text-end">
                                <a asp-controller="Order" asp-action="Receipt" asp-route-id="@o.Id"
                                   class="btn btn-sm btn-link" title="Makbuz">📄</a>
                                <a asp-controller="Order" asp-action="Agreement" asp-route-id="@o.Id"
                                   class="btn btn-sm btn-link" title="Sözleşme">📋</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (totalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center mb-0">
                @if (currentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Orders" asp-route-status="@currentStatus"
                           asp-route-page="@(currentPage - 1)">Önceki</a>
                    </li>
                }
                <li class="page-item active"><span class="page-link">@(currentPage) / @totalPages</span></li>
                @if (currentPage < totalPages)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Orders" asp-route-status="@currentStatus"
                           asp-route-page="@(currentPage + 1)">Sonraki</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
