@{
    ViewData["Title"] = "Restoran Panel";
}

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <h2 class="mb-2">Restoran Panel</h2>
        <p class="text-muted">Menülerini, siparişlerini ve istatistikleri buradan yönetebilirsin.</p>

        <div class="row g-3 mt-2">
            <div class="col-md-4">
                <a href="/Caterer/Menu" class="btn btn-primary w-100 py-3">Menü Yönetimi</a>
            </div>
            <div class="col-md-4">
                <a href="/Caterer/Orders" class="btn btn-outline-primary w-100 py-3">Gelen Siparişler</a>
            </div>
            <div class="col-md-4">
                <a asp-controller="Account" asp-action="Profile" class="btn btn-outline-primary w-100 py-3">
                    Restoran Bilgileri
                </a>
            </div>
        </div>

        <hr class="my-4" />
        <small class="text-muted">İstatistikler ve detaylı panel yakında.</small>
    </div>
</div>
