@{
    ViewData["Title"] = "Ödeme Onaylandı";
    var items = ViewBag.Items as List<EnrichedCartItem>;
    var total = (decimal)ViewBag.Total;
    var catererName = ViewBag.CatererName as string;
    var deliveryInfo = ViewBag.DeliveryInfo as DeliveryInfo;
}

<div class="text-center my-4">
    <div style="font-size:5rem;color:#28a745;line-height:1;">✓</div>
    <h2 class="mt-2">Ödemen Onaylandı!</h2>
    <p class="text-muted">Şimdi siparişini oluştur, restoran tarafına iletilsin.</p>
</div>

<div class="card mx-auto border-0 shadow-sm" style="max-width:600px;">
    <div class="card-body p-4">
        <h5 class="mb-3">@catererName</h5>
        @if (items != null)
        {
            foreach (var item in items)
            {
                <div class="d-flex justify-content-between border-bottom py-2">
                    <span>@item.Quantity × @item.Name</span>
                    <span>₺@item.Subtotal.ToString("0.00")</span>
                </div>
            }
        }
        <div class="d-flex justify-content-between mt-3"
             style="font-size:1.3rem;font-weight:600;color:var(--sofra-primary);">
            <span>Toplam:</span>
            <span>₺@total.ToString("0.00")</span>
        </div>
        @if (deliveryInfo != null)
        {
            <hr />
            <small class="text-muted">Teslimat: @deliveryInfo.Address</small>
        }
    </div>
</div>

<div class="text-center mt-4">
    <form asp-controller="Order" asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-primary btn-lg">Siparişini Oluştur</button>
    </form>
    <small class="text-muted d-block mt-2">Bu butona basınca sipariş oluşturulup restorana iletilir.</small>
</div>
