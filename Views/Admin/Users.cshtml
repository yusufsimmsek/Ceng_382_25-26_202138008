@{
    ViewData["Title"] = "Kullanıcılar";
    var users = ViewBag.Users as List<Sofranet.Controllers.AdminUserRow>
        ?? new List<Sofranet.Controllers.AdminUserRow>();
    var q = ViewBag.Query as string;
    var roleFilter = ViewBag.RoleFilter as string;
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
    var total = (int)(ViewBag.Total ?? 0);
}

<h2 class="mb-1">Kullanıcılar</h2>
<p class="text-muted mb-3">Toplam @total kullanıcı</p>

<div class="filter-bar">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-md-5">
            <input type="text" name="q" value="@q" class="form-control" placeholder="İsim veya email..." />
        </div>
        <div class="col-md-3">
            <select name="role" class="form-select">
                <option value="">Tüm Roller</option>
                <option value="Admin" selected="@(roleFilter == "Admin")">Admin</option>
                <option value="Caterer" selected="@(roleFilter == "Caterer")">Caterer</option>
                <option value="User" selected="@(roleFilter == "User")">User</option>
            </select>
        </div>
        <div class="col-md-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Filtrele</button>
            <a asp-action="Users" class="btn btn-link">Temizle</a>
        </div>
    </form>
</div>

<div class="card border-0 shadow-sm mt-3">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>İsim</th><th>Email</th><th>Rol</th><th>Telefon</th><th>Adres</th><th>Kayıt</th></tr>
            </thead>
            <tbody>
            @foreach (var u in users)
            {
                <tr>
                    <td>@u.FullName</td>
                    <td>@u.Email</td>
                    <td><span class="role-badge role-@(u.Role.ToLower())">@u.Role</span></td>
                    <td>@(string.IsNullOrEmpty(u.PhoneNumber) ? "-" : u.PhoneNumber)</td>
                    <td>
                        @{
                            var addr = u.Address;
                        }
                        @(string.IsNullOrEmpty(addr) ? "-" : (addr.Length > 40 ? addr.Substring(0, 40) + "..." : addr))
                    </td>
                    <td>@u.CreatedAt.ToString("dd.MM.yyyy")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center mb-0">
            @if (currentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Users" asp-route-q="@q" asp-route-role="@roleFilter"
                       asp-route-page="@(currentPage - 1)">Önceki</a>
                </li>
            }
            <li class="page-item active"><span class="page-link">@(currentPage) / @totalPages</span></li>
            @if (currentPage < totalPages)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Users" asp-route-q="@q" asp-route-role="@roleFilter"
                       asp-route-page="@(currentPage + 1)">Sonraki</a>
                </li>
            }
        </ul>
    </nav>
}
