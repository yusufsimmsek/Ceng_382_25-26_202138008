@{
    ViewData["Title"] = "Restoranlar";
    var caterers = ViewBag.Caterers as List<Sofranet.Controllers.AdminCatererRow>
        ?? new List<Sofranet.Controllers.AdminCatererRow>();
    var q = ViewBag.Query as string;
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
    var total = (int)(ViewBag.Total ?? 0);
}

<h2 class="mb-1">Restoranlar</h2>
<p class="text-muted mb-3">Toplam @total restoran</p>

<div class="filter-bar">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-md-6">
            <input type="text" name="q" value="@q" class="form-control" placeholder="Restoran adı veya email..." />
        </div>
        <div class="col-md-6 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Filtrele</button>
            <a asp-action="Caterers" class="btn btn-link">Temizle</a>
        </div>
    </form>
</div>

<div class="card border-0 shadow-sm mt-3">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Restoran</th><th>Email</th><th>Telefon</th>
                    <th>Sipariş</th><th>Gelir</th><th>Puan</th><th>Menüler</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var c in caterers)
            {
                <tr>
                    <td>
                        <div class="fw-semibold">@c.FullName</div>
                        @if (!string.IsNullOrEmpty(c.Address))
                        {
                            <small class="text-muted">@(c.Address.Length > 50 ? c.Address.Substring(0, 50) + "..." : c.Address)</small>
                        }
                    </td>
                    <td>@c.Email</td>
                    <td>@(string.IsNullOrEmpty(c.PhoneNumber) ? "-" : c.PhoneNumber)</td>
                    <td>@c.OrderCount</td>
                    <td>₺@c.Revenue.ToString("0.00")</td>
                    <td>
                        @if (c.AvgRating.HasValue)
                        {
                            <span class="rating-stars">★ @c.AvgRating.Value.ToString("0.0")</span>
                            <small class="text-muted">(@c.RatingCount)</small>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td>
                        <a asp-controller="Menu" asp-action="Index" asp-route-caterer="@c.Id"
                           class="btn btn-sm btn-link">Menüleri</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center mb-0">
            @if (currentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Caterers" asp-route-q="@q"
                       asp-route-page="@(currentPage - 1)">Önceki</a>
                </li>
            }
            <li class="page-item active"><span class="page-link">@(currentPage) / @totalPages</span></li>
            @if (currentPage < totalPages)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Caterers" asp-route-q="@q"
                       asp-route-page="@(currentPage + 1)">Sonraki</a>
                </li>
            }
        </ul>
    </nav>
}
