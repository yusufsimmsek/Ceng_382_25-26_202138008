@{
    ViewData["Title"] = "Tüm Siparişler";
    var orders = ViewBag.Orders as List<Sofranet.Controllers.AdminOrderRow>
        ?? new List<Sofranet.Controllers.AdminOrderRow>();
    var status = ViewBag.Status as string;
    var df = ViewBag.DateFrom as string;
    var dt = ViewBag.DateTo as string;
    var q = ViewBag.Query as string;
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
    var total = (int)(ViewBag.Total ?? 0);

    string StatusLabel(string s) => s switch
    {
        "pending" => "Bekliyor",
        "preparing" => "Hazırlanıyor",
        "completed" => "Tamamlandı",
        "cancelled" => "İptal",
        _ => s
    };
}

<h2 class="mb-1">Tüm Siparişler</h2>
<p class="text-muted mb-3">Toplam @total sipariş</p>

<div class="filter-bar">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-md-2">
            <select name="status" class="form-select">
                <option value="">Tüm Durumlar</option>
                <option value="pending" selected="@(status == "pending")">Bekliyor</option>
                <option value="preparing" selected="@(status == "preparing")">Hazırlanıyor</option>
                <option value="completed" selected="@(status == "completed")">Tamamlandı</option>
                <option value="cancelled" selected="@(status == "cancelled")">İptal</option>
            </select>
        </div>
        <div class="col-md-2">
            <input type="date" name="dateFrom" value="@df" class="form-control" />
        </div>
        <div class="col-md-2">
            <input type="date" name="dateTo" value="@dt" class="form-control" />
        </div>
        <div class="col-md-3">
            <input type="text" name="q" value="@q" class="form-control" placeholder="Müşteri/restoran..." />
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Filtrele</button>
            <a asp-action="Orders" class="btn btn-link">Temizle</a>
        </div>
    </form>
</div>

<div class="card border-0 shadow-sm mt-3">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th><th>Tarih</th><th>Müşteri</th>
                    <th>Restoran</th><th>Tutar</th><th>Durum</th><th>PDF</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var o in orders)
            {
                <tr>
                    <td>#@o.Id</td>
                    <td>@o.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>
                        @o.UserName
                        <br /><small class="text-muted">@o.UserEmail</small>
                    </td>
                    <td>@o.CatererName</td>
                    <td>₺@o.TotalAmount.ToString("0.00")</td>
                    <td><span class="status-badge status-@o.Status">@StatusLabel(o.Status)</span></td>
                    <td>
                        <a asp-controller="Order" asp-action="Receipt" asp-route-id="@o.Id"
                           class="btn btn-sm btn-link" title="Makbuz">📄</a>
                        <a asp-controller="Order" asp-action="Agreement" asp-route-id="@o.Id"
                           class="btn btn-sm btn-link" title="Sözleşme">📋</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center mb-0">
            @if (currentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Orders"
                       asp-route-status="@status" asp-route-dateFrom="@df" asp-route-dateTo="@dt"
                       asp-route-q="@q" asp-route-page="@(currentPage - 1)">Önceki</a>
                </li>
            }
            <li class="page-item active"><span class="page-link">@(currentPage) / @totalPages</span></li>
            @if (currentPage < totalPages)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Orders"
                       asp-route-status="@status" asp-route-dateFrom="@df" asp-route-dateTo="@dt"
                       asp-route-q="@q" asp-route-page="@(currentPage + 1)">Sonraki</a>
                </li>
            }
        </ul>
    </nav>
}
