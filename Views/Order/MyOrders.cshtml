@model List<Sofranet.Controllers.OrderListItem>
@{
    ViewData["Title"] = "Siparişlerim";
    var currentStatus = ViewBag.Status as string;
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
    var total = (int)(ViewBag.Total ?? 0);

    string StatusLabel(string s) => s switch
    {
        "pending" => "Bekliyor",
        "preparing" => "Hazırlanıyor",
        "completed" => "Tamamlandı",
        "cancelled" => "İptal",
        _ => s
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0">Siparişlerim</h2>
        <small class="text-muted">@total kayıt</small>
    </div>
</div>

<form method="get" class="mb-3 d-flex gap-2 align-items-center">
    <label class="small mb-0">Durum:</label>
    <select name="status" class="form-select form-select-sm d-inline-block" style="width:auto;"
            onchange="this.form.submit()">
        <option value="">Tümü</option>
        <option value="pending" selected="@(currentStatus == "pending")">Bekliyor</option>
        <option value="preparing" selected="@(currentStatus == "preparing")">Hazırlanıyor</option>
        <option value="completed" selected="@(currentStatus == "completed")">Tamamlandı</option>
        <option value="cancelled" selected="@(currentStatus == "cancelled")">İptal</option>
    </select>
    @if (!string.IsNullOrEmpty(currentStatus))
    {
        <a asp-action="MyOrders" class="btn btn-sm btn-link">Temizle</a>
    }
</form>

@if (Model.Count == 0)
{
    <div class="text-center py-5 text-muted">
        <div style="font-size:3rem;">📦</div>
        <p>Henüz sipariş yok</p>
        <a asp-controller="Menu" asp-action="Index" class="btn btn-primary">Menülere göz at</a>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Tarih</th>
                        <th>Restoran</th>
                        <th>Ürün</th>
                        <th>Tutar</th>
                        <th>Durum</th>
                        <th class="text-end">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Model)
                    {
                        <tr>
                            <td>#@o.Id</td>
                            <td>@o.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@o.CatererName</td>
                            <td>@o.ItemCount adet</td>
                            <td>₺@o.TotalAmount.ToString("0.00")</td>
                            <td><span class="status-badge status-@o.Status">@StatusLabel(o.Status)</span></td>
                            <td class="text-end">
                                <a asp-action="Success" asp-route-id="@o.Id" class="btn btn-sm btn-link">Detay</a>
                                <a asp-action="Receipt" asp-route-id="@o.Id" class="btn btn-sm btn-link" title="Makbuz">📄</a>
                                <a asp-action="Agreement" asp-route-id="@o.Id" class="btn btn-sm btn-link" title="Sözleşme">📋</a>
                                @if (o.Status == "completed" && !o.HasRating)
                                {
                                    <a asp-controller="Rating" asp-action="Rate" asp-route-id="@o.Id"
                                       class="btn btn-sm btn-warning">Değerlendir</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (totalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center mb-0">
                @if (currentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="MyOrders" asp-route-status="@currentStatus"
                           asp-route-page="@(currentPage - 1)">Önceki</a>
                    </li>
                }
                <li class="page-item active"><span class="page-link">@(currentPage) / @totalPages</span></li>
                @if (currentPage < totalPages)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="MyOrders" asp-route-status="@currentStatus"
                           asp-route-page="@(currentPage + 1)">Sonraki</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
