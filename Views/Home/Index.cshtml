@{
    ViewData["Title"] = "Anasayfa";
}

<div class="hero text-center">
    <div class="container">
        <h1 class="hero-title">🍽️ Sofranet</h1>
        <p class="hero-tagline">Mahallendeki lezzet kapına gelsin</p>
        <p class="lead text-muted mb-4">
            Çevrendeki yerel restoranlardan online sipariş ver, en sevdiklerini keşfet.
        </p>
        <div class="mt-4">
            <a asp-controller="Menu" asp-action="Index" class="btn-cta">Menülere Göz At</a>
            <a asp-controller="Account" asp-action="Register" class="btn-cta-outline ms-2">Hemen Üye Ol</a>
        </div>
    </div>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="feature-card">
            <div class="feature-icon">📍</div>
            <div class="feature-title">Yakındaki Restoranlar</div>
            <p class="feature-text">Konumuna göre en yakın yerel mutfakları keşfet.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="feature-card">
            <div class="feature-icon">🛒</div>
            <div class="feature-title">Kolay Sipariş</div>
            <p class="feature-text">Customize et, sepete ekle, dakikalar içinde siparişini tamamla.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="feature-card">
            <div class="feature-icon">⚡</div>
            <div class="feature-title">Hızlı Teslimat</div>
            <p class="feature-text">Yerel restoranlardan taze ve sıcak yemek hızla kapına gelsin.</p>
        </div>
    </div>
</div>
