<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Sofranet - Mahallendeki lezzet kapına gelsin. Yerel restoranlardan online sipariş ver.">
  <meta name="theme-color" content="#E63946">
  <link rel="icon" type="image/svg+xml" href="/images/logo.svg">
  <title><%= typeof title !== 'undefined' && title ? title + ' - Sofranet' : 'Sofranet' %></title>

  <!-- bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- google fonts poppins -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="<%= (user ? 'role-' + user.role : '') %> <%= typeof bodyClass !== 'undefined' && bodyClass ? bodyClass : '' %>">
  <%- include('partials/navbar') %>

  <main class="container py-4">
    <%- include('partials/flash') %>
    <%- body %>
  </main>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/forms.js"></script>

  <% if (typeof needsMaps !== 'undefined' && needsMaps) { %>
    <% var validKey = googleMapsKey && googleMapsKey !== 'placeholder' && !googleMapsKey.startsWith('your_'); %>
    <% if (validKey) { %>
      <script src="/js/maps.js"></script>
      <script async defer src="https://maps.googleapis.com/maps/api/js?key=<%= googleMapsKey %>&callback=initMaps"></script>
    <% } else { %>
      <script>window.GMAPS_DISABLED = true;</script>
      <script src="/js/maps.js"></script>
    <% } %>
  <% } %>
</body>
</html>
