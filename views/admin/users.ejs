<h2 class="mt-3 mb-3">Kullanıcılar</h2>

<div class="filter-bar">
  <form method="GET" action="/admin/users" class="row g-2 align-items-end">
    <div class="col-md-5">
      <label class="form-label small">Ara (isim / email)</label>
      <input type="text" name="q" class="form-control" value="<%= filters.q %>">
    </div>
    <div class="col-md-3">
      <label class="form-label small">Rol</label>
      <select name="role" class="form-select">
        <option value="">Tümü</option>
        <option value="user" <%= filters.role === 'user' ? 'selected' : '' %>>Kullanıcı</option>
        <option value="caterer" <%= filters.role === 'caterer' ? 'selected' : '' %>>Caterer</option>
        <option value="admin" <%= filters.role === 'admin' ? 'selected' : '' %>>Admin</option>
      </select>
    </div>
    <div class="col-md-4 d-flex gap-2">
      <button type="submit" class="btn btn-primary">Filtrele</button>
      <a href="/admin/users" class="btn btn-outline-secondary">Temizle</a>
    </div>
  </form>
</div>

<% if (!users || users.length === 0) { %>
  <div class="empty-state text-center p-5">
    <p class="text-muted mb-0">Sonuç bulunamadı.</p>
  </div>
<% } else { %>
  <div class="card shadow-sm border-0">
    <div class="table-responsive">
      <table class="table mb-0 align-middle">
        <thead>
          <tr>
            <th>#</th><th>İsim</th><th>Email</th>
            <th>Rol</th><th>Telefon</th><th>Adres</th><th>Kayıt</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(function(u){ %>
            <tr>
              <td>#<%= u.id %></td>
              <td><%= u.name %></td>
              <td><%= u.email %></td>
              <td><span class="role-badge role-<%= u.role %>"><%= u.role %></span></td>
              <td><%= u.phone || '-' %></td>
              <td><%= u.address ? (u.address.length > 40 ? u.address.substring(0, 40) + '...' : u.address) : '-' %></td>
              <td><%= new Date(u.created_at).toLocaleDateString('tr-TR') %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <%- include('../partials/pagination', { pagination, currentQuery, baseUrl: '/admin/users' }) %>
<% } %>
