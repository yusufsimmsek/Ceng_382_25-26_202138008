<h2 class="mt-3 mb-3">Caterer'lar</h2>

<div class="filter-bar">
  <form method="GET" action="/admin/caterers" class="row g-2 align-items-end">
    <div class="col-md-6">
      <label class="form-label small">Ara (isim / email)</label>
      <input type="text" name="q" class="form-control" value="<%= filters.q %>">
    </div>
    <div class="col-md-6 d-flex gap-2">
      <button type="submit" class="btn btn-primary">Filtrele</button>
      <a href="/admin/caterers" class="btn btn-outline-secondary">Temizle</a>
    </div>
  </form>
</div>

<% if (!caterers || caterers.length === 0) { %>
  <div class="empty-state text-center p-5">
    <p class="text-muted mb-0">Sonuç bulunamadı.</p>
  </div>
<% } else { %>
  <div class="card shadow-sm border-0">
    <div class="table-responsive">
      <table class="table mb-0 align-middle">
        <thead>
          <tr>
            <th>#</th><th>İsim</th><th>Email</th><th>Telefon</th>
            <th>Sipariş</th><th>Gelir</th><th>Puan</th><th></th>
          </tr>
        </thead>
        <tbody>
          <% caterers.forEach(function(c){ %>
            <tr>
              <td>#<%= c.id %></td>
              <td><%= c.name %></td>
              <td><%= c.email %></td>
              <td><%= c.phone || '-' %></td>
              <td><%= c.order_count %></td>
              <td>₺<%= Number(c.revenue).toFixed(2) %></td>
              <td>
                <% if (c.avg_rating) { %>
                  ⭐ <%= Number(c.avg_rating).toFixed(1) %>
                <% } else { %>
                  -
                <% } %>
              </td>
              <td>
                <a href="/menu?caterer=<%= c.id %>" class="btn btn-sm btn-outline-secondary">Menüleri</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <%- include('../partials/pagination', { pagination, currentQuery, baseUrl: '/admin/caterers' }) %>
<% } %>
