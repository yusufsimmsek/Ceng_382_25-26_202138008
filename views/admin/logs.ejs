<%
function actionClass(action) {
  if (['LOGIN_SUCCESS','USER_REGISTERED'].includes(action)) return 'log-action-success';
  if (['LOGIN_FAIL','PAYMENT_FAILED','EMAIL_FAILED','ERROR'].includes(action)) return 'log-action-error';
  if (action && (action.startsWith('ORDER_') || action.startsWith('MENU_') || action.startsWith('RATING_'))) return 'log-action-info';
  return 'log-action-default';
}
function formatDT(d) {
  if (!d) return '';
  var dt = new Date(d);
  var pad = function(n){ return String(n).padStart(2, '0'); };
  return pad(dt.getDate()) + '.' + pad(dt.getMonth()+1) + '.' + dt.getFullYear() + ' ' +
         pad(dt.getHours()) + ':' + pad(dt.getMinutes()) + ':' + pad(dt.getSeconds());
}
%>

<h2 class="mt-3 mb-3">Sistem Logları</h2>

<div class="filter-bar">
  <form method="GET" action="/admin/logs">
    <div class="row g-2 align-items-end">
      <div class="col-md-3">
        <label class="form-label small">Action</label>
        <select name="action" class="form-select">
          <option value="">Tümü</option>
          <% actions.forEach(function(a){ %>
            <option value="<%= a %>" <%= filters.action === a ? 'selected' : '' %>><%= a %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-3">
        <label class="form-label small">Kullanıcı (email/isim)</label>
        <input type="text" name="q" class="form-control" value="<%= filters.q %>">
      </div>
      <div class="col-md-2">
        <label class="form-label small">IP</label>
        <input type="text" name="ip" class="form-control" value="<%= filters.ip %>">
      </div>
      <div class="col-md-2">
        <label class="form-label small">Tarih Başlangıç</label>
        <input type="date" name="date_from" class="form-control" value="<%= filters.date_from %>">
      </div>
      <div class="col-md-2">
        <label class="form-label small">Tarih Bitiş</label>
        <input type="date" name="date_to" class="form-control" value="<%= filters.date_to %>">
      </div>
    </div>
    <div class="d-flex gap-2 mt-2 align-items-center">
      <button type="submit" class="btn btn-primary btn-sm">Filtrele</button>
      <a href="/admin/logs" class="btn btn-outline-secondary btn-sm">Temizle</a>
      <span class="text-muted small ms-auto">Toplam <%= pagination.total %> kayıt</span>
    </div>
  </form>
</div>

<% if (!logs || logs.length === 0) { %>
  <div class="empty-state text-center p-5">
    <p class="text-muted mb-0">Bu kriterlere uygun log yok.</p>
  </div>
<% } else { %>
  <div class="card shadow-sm border-0">
    <div class="table-responsive">
      <table class="table table-striped table-hover mb-0 align-middle">
        <thead>
          <tr>
            <th>Tarih</th>
            <th>Action</th>
            <th>Kullanıcı</th>
            <th>IP</th>
            <th>Detay</th>
          </tr>
        </thead>
        <tbody>
          <% logs.forEach(function(l){ %>
            <tr class="log-row">
              <td class="log-date"><%= formatDT(l.created_at) %></td>
              <td>
                <span class="log-action <%= actionClass(l.action) %>"><%= l.action %></span>
              </td>
              <td>
                <% if (l.user_email) { %>
                  <%= l.user_email %>
                  <% if (l.user_role) { %>
                    <span class="role-badge role-<%= l.user_role %> ms-1"><%= l.user_role %></span>
                  <% } %>
                <% } else { %>
                  <span class="text-muted">anonim</span>
                <% } %>
              </td>
              <td class="log-ip"><%= l.ip_address || '-' %></td>
              <td class="log-details" title="<%= l.details || '' %>">
                <%= l.details ? (l.details.length > 60 ? l.details.substring(0, 60) + '...' : l.details) : '-' %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <%- include('../partials/pagination', { pagination, currentQuery, baseUrl: '/admin/logs' }) %>
<% } %>
