<h2 class="mt-3 mb-3">Gelen Siparişler</h2>

<% var statusLabels = { pending:'Bekliyor', preparing:'Hazırlanıyor', completed:'Tamamlandı', cancelled:'İptal' }; %>

<div class="filter-bar">
  <form method="GET" action="/caterer/orders" class="row g-2 align-items-end">
    <div class="col-md-4">
      <label class="form-label small">Durum</label>
      <select name="status" class="form-select">
        <option value="">Tümü</option>
        <% ['pending','preparing','completed','cancelled'].forEach(function(s){ %>
          <option value="<%= s %>" <%= statusFilter === s ? 'selected' : '' %>>
            <%= statusLabels[s] %>
          </option>
        <% }) %>
      </select>
    </div>
    <div class="col-md-3 d-flex gap-2">
      <button type="submit" class="btn btn-primary">Filtrele</button>
      <a href="/caterer/orders" class="btn btn-outline-secondary">Temizle</a>
    </div>
  </form>
</div>

<% if (!orders || orders.length === 0) { %>
  <div class="empty-state text-center p-5">
    <div style="font-size: 3rem;">📥</div>
    <% if (statusFilter) { %>
      <p class="text-muted mb-0">Bu kriterlere uygun sipariş bulunamadı. Filtreyi temizlemeyi dene.</p>
    <% } else { %>
      <p class="text-muted mb-0">Henüz siparişin yok.</p>
    <% } %>
  </div>
<% } else { %>
  <div class="card shadow-sm border-0">
    <div class="table-responsive">
      <table class="table mb-0 align-middle">
        <thead>
          <tr>
            <th>#</th>
            <th>Tarih</th>
            <th>Müşteri</th>
            <th>Ürün</th>
            <th>Toplam</th>
            <th>Durum</th>
            <th class="text-end">Durumu Güncelle</th>
          </tr>
        </thead>
        <tbody>
          <% orders.forEach(function(o){ %>
            <tr>
              <td>#<%= o.id %></td>
              <td><%= new Date(o.created_at).toLocaleDateString('tr-TR') %></td>
              <td>
                <%= o.user_name %>
                <div class="small text-muted"><%= o.user_email %></div>
              </td>
              <td><%= o.item_count %></td>
              <td>₺<%= Number(o.total_amount).toFixed(2) %></td>
              <td>
                <span class="status-badge status-<%= o.status %>">
                  <%= statusLabels[o.status] || o.status %>
                </span>
              </td>
              <td class="text-end">
                <form action="/caterer/orders/<%= o.id %>/status" method="POST"
                      class="d-flex gap-1 justify-content-end m-0">
                  <select name="status" class="form-select form-select-sm" style="width: auto;">
                    <% ['pending','preparing','completed','cancelled'].forEach(function(s){ %>
                      <option value="<%= s %>" <%= o.status === s ? 'selected' : '' %>>
                        <%= statusLabels[s] %>
                      </option>
                    <% }) %>
                  </select>
                  <button type="submit" class="btn btn-sm btn-outline-primary">Kaydet</button>
                  <a href="/orders/<%= o.id %>/receipt" class="btn btn-sm btn-outline-secondary" title="Makbuzu indir">📄</a>
                  <a href="/orders/<%= o.id %>/agreement" class="btn btn-sm btn-outline-secondary" title="Sözleşmeyi indir">📋</a>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <%- include('../partials/pagination', { pagination, currentQuery, baseUrl: '/caterer/orders' }) %>
<% } %>
