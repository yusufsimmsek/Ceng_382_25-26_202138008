<div class="d-flex justify-content-between align-items-center mt-3 mb-3">
  <h2 class="mb-0">Menü Yönetimi</h2>
  <a href="/caterer/menu/new" class="btn btn-primary">+ Yeni Menü Ekle</a>
</div>

<% if (!items || items.length === 0) { %>
  <div class="empty-state text-center p-5">
    <div style="font-size: 3rem;">🍽️</div>
    <p class="text-muted mb-0">Henüz menü oluşturmadın. İlk menünü ekleyerek başla.</p>
  </div>
<% } else { %>
  <div class="card border-0 shadow-sm">
    <div class="table-responsive">
      <table class="table mb-0 align-middle">
        <thead>
          <tr>
            <th>Görsel</th>
            <th>İsim</th>
            <th>Fiyat</th>
            <th>Durum</th>
            <th class="text-end">İşlemler</th>
          </tr>
        </thead>
        <tbody>
          <% items.forEach(function(it){ %>
            <tr>
              <td>
                <img src="<%= it.image_path || '/images/no-image.svg' %>"
                     alt="<%= it.name %>" class="menu-thumb">
              </td>
              <td><%= it.name %></td>
              <td>₺<%= Number(it.price).toFixed(2) %></td>
              <td>
                <% if (it.is_available) { %>
                  <span class="badge badge-active">Aktif</span>
                <% } else { %>
                  <span class="badge badge-inactive">Pasif</span>
                <% } %>
              </td>
              <td class="text-end">
                <a href="/caterer/menu/<%= it.id %>/edit" class="btn btn-sm btn-outline-secondary">Düzenle</a>
                <form action="/caterer/menu/<%= it.id %>?_method=DELETE" method="POST" class="d-inline"
                      onsubmit="return confirm('Bu menüyü silmek istediğine emin misin?');">
                  <button type="submit" class="btn btn-sm btn-outline-danger">Sil</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>
