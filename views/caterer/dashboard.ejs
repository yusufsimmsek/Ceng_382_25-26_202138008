<div class="mt-3">
  <h2 class="mb-1">Hoş geldin, <%= user.name %>!</h2>
  <p class="text-muted mb-4"><%= user.name %> - Caterer Paneli</p>

  <% var statusLabels = { pending:'Bekliyor', preparing:'Hazırlanıyor', completed:'Tamamlandı', cancelled:'İptal' }; %>

  <% if (Number(stats.pending_orders) > 0) { %>
    <div class="pending-alert">
      <div class="alert-text">
        ⏰ <%= stats.pending_orders %> bekleyen siparişin var
      </div>
      <a href="/caterer/orders?status=pending" class="btn btn-warning btn-sm">Siparişleri Gör</a>
    </div>
  <% } %>

  <div class="row g-3">
    <div class="col-md-3 col-sm-6">
      <div class="stat-card text-center">
        <div class="stat-icon">📦</div>
        <div class="stat-value"><%= stats.total_orders %></div>
        <div class="stat-label">Toplam Sipariş</div>
      </div>
    </div>

    <div class="col-md-3 col-sm-6">
      <div class="stat-card text-center">
        <div class="stat-icon">✅</div>
        <div class="stat-value"><%= stats.completed_orders %></div>
        <div class="stat-label">Tamamlanan</div>
      </div>
    </div>

    <div class="col-md-3 col-sm-6">
      <div class="stat-card text-center">
        <div class="stat-icon">⭐</div>
        <div class="stat-value">
          <% if (stats.avg_rating) { %>
            <%= Number(stats.avg_rating).toFixed(2) %>
          <% } else { %>
            <span class="stat-empty">-</span>
          <% } %>
        </div>
        <div class="stat-label">
          <% if (stats.avg_rating) { %>
            Ortalama Puan (<%= stats.rating_count %> değerlendirme)
          <% } else { %>
            Henüz değerlendirme yok
          <% } %>
        </div>
      </div>
    </div>

    <div class="col-md-3 col-sm-6">
      <div class="stat-card text-center">
        <div class="stat-icon">💰</div>
        <div class="stat-value">₺<%= Number(stats.total_revenue).toFixed(2) %></div>
        <div class="stat-label">Toplam Gelir</div>
      </div>
    </div>
  </div>

  <% if (topItems && topItems.length > 0) { %>
    <h4 class="mt-4 mb-3">En Çok Satan Ürünler</h4>
    <div class="row g-3">
      <% topItems.forEach(function(it){ %>
        <div class="col-md-4">
          <div class="top-item-card">
            <img src="<%= it.image_path || '/images/no-image.svg' %>" alt="<%= it.name %>">
            <div class="mt-2"><strong><%= it.name %></strong></div>
            <div class="top-item-qty mt-1">
              <%= it.total_qty %> adet satıldı
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

  <div class="mt-4 d-flex justify-content-between align-items-center">
    <h4 class="mb-0">Son Siparişler</h4>
    <a href="/caterer/orders" class="small">Tümünü gör →</a>
  </div>

  <% if (!recentOrders || recentOrders.length === 0) { %>
    <div class="empty-state text-center p-5 mt-3">
      <div style="font-size: 2.5rem;">📥</div>
      <p class="text-muted mb-0">Henüz sipariş yok.</p>
    </div>
  <% } else { %>
    <div class="card shadow-sm border-0 mt-3">
      <div class="table-responsive">
        <table class="table mb-0 align-middle">
          <thead>
            <tr>
              <th>#</th>
              <th>Tarih</th>
              <th>Müşteri</th>
              <th>Tutar</th>
              <th>Durum</th>
            </tr>
          </thead>
          <tbody>
            <% recentOrders.forEach(function(o){ %>
              <tr>
                <td>#<%= o.id %></td>
                <td><%= new Date(o.created_at).toLocaleDateString('tr-TR') %></td>
                <td><%= o.user_name %></td>
                <td>₺<%= Number(o.total_amount).toFixed(2) %></td>
                <td>
                  <span class="status-badge status-<%= o.status %>">
                    <%= statusLabels[o.status] || o.status %>
                  </span>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>

  <div class="row g-3 mt-4">
    <div class="col-md-6">
      <div class="quick-card">
        <h5>Menü Yönetimi</h5>
        <p class="text-muted">Menü itemlarını ekle, düzenle, customization tanımla.</p>
        <a href="/caterer/menu" class="btn btn-primary">Menüye Git</a>
      </div>
    </div>

    <div class="col-md-6">
      <div class="quick-card">
        <h5>Siparişler</h5>
        <p class="text-muted">Bekleyen ve tamamlanan siparişleri gör.</p>
        <a href="/caterer/orders" class="btn btn-primary">Siparişleri Aç</a>
      </div>
    </div>
  </div>
</div>
