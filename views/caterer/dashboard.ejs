<div class="mt-3">
  <h2 class="mb-1">Hoş geldin, <%= user.name %>!</h2>
  <p class="text-muted mb-4"><%= user.name %> - Caterer Paneli</p>

  <div class="row g-3">
    <div class="col-md-3 col-sm-6">
      <div class="stat-card text-center">
        <div class="stat-icon">📦</div>
        <div class="stat-value"><%= stats.totalOrders %></div>
        <div class="stat-label">Toplam Sipariş</div>
      </div>
    </div>

    <div class="col-md-3 col-sm-6">
      <div class="stat-card text-center">
        <div class="stat-icon">✅</div>
        <div class="stat-value"><%= stats.completed %></div>
        <div class="stat-label">Tamamlanan</div>
      </div>
    </div>

    <div class="col-md-3 col-sm-6">
      <div class="stat-card text-center">
        <div class="stat-icon">⭐</div>
        <div class="stat-value">
          <% if (stats.avgRating) { %>
            <%= Number(stats.avgRating).toFixed(1) %>
          <% } else { %>
            <span class="stat-empty">-</span>
          <% } %>
        </div>
        <div class="stat-label">
          <% if (stats.avgRating) { %>
            Ortalama Puan
          <% } else { %>
            Henüz değerlendirme yok
          <% } %>
        </div>
      </div>
    </div>

    <div class="col-md-3 col-sm-6">
      <div class="stat-card text-center">
        <div class="stat-icon">💰</div>
        <div class="stat-value">₺<%= stats.revenue %></div>
        <div class="stat-label">Toplam Gelir</div>
      </div>
    </div>
  </div>

  <div class="row g-3 mt-4">
    <div class="col-md-6">
      <div class="quick-card">
        <h5>Menü Yönetimi</h5>
        <p class="text-muted">Menü itemlarını ekle, düzenle, customization tanımla.</p>
        <a href="/caterer/menu" class="btn btn-primary">Menüye Git</a>
      </div>
    </div>

    <div class="col-md-6">
      <div class="quick-card">
        <h5>Siparişler</h5>
        <p class="text-muted">Bekleyen ve tamamlanan siparişleri gör.</p>
        <a href="/caterer/orders" class="btn btn-primary">Siparişleri Aç</a>
      </div>
    </div>
  </div>

  <p class="text-muted small mt-4 text-center">
    İstatistikler ilk siparişle dolmaya başlayacak.
  </p>
</div>
