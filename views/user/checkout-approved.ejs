<div class="approved-banner">
  <div class="checkmark">✓</div>
  <h2 class="mt-3">Ödemen onaylandı!</h2>
  <p class="text-muted">Şimdi siparişini oluşturarak süreci tamamlayabilirsin.</p>
</div>

<div class="row justify-content-center mt-3">
  <div class="col-md-7">
    <div class="card shadow-sm border-0 mb-3">
      <div class="card-body p-4">
        <h5 class="mb-3">Sipariş Özeti</h5>
        <% if (caterer) { %>
          <div class="text-muted small mb-2"><%= caterer.name %></div>
        <% } %>

        <% cartItems.forEach(function(ci){ %>
          <div class="checkout-summary-item">
            <div class="d-flex justify-content-between">
              <span><%= ci.quantity %>x <%= ci.menuItem ? ci.menuItem.name : '(silinmiş)' %></span>
              <span>₺<%= ci.subtotal.toFixed(2) %></span>
            </div>
          </div>
        <% }) %>

        <div class="d-flex justify-content-between mt-3 pt-3" style="border-top: 1px solid #ddd;">
          <strong>Toplam</strong>
          <strong style="color: var(--primary); font-size: 1.4rem;">₺<%= total.toFixed(2) %></strong>
        </div>

        <% if (deliveryInfo && deliveryInfo.address) { %>
          <div class="mt-3 pt-3" style="border-top: 1px solid #eee;">
            <div class="text-muted small">Teslimat adresi</div>
            <div><%= deliveryInfo.address %></div>
          </div>
        <% } %>
      </div>
    </div>

    <form action="/orders/create" method="POST">
      <button type="submit" class="btn btn-primary btn-lg w-100">Siparişini Oluştur</button>
    </form>
  </div>
</div>
