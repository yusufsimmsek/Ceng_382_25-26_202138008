<div class="mt-3">
  <h2 class="mb-1">Hoş geldin, <%= user.name %>!</h2>
  <p class="text-muted mb-4">Sofranet üzerindeki siparişlerinin özeti.</p>

  <% var statusLabels = { pending:'Bekliyor', preparing:'Hazırlanıyor', completed:'Tamamlandı', cancelled:'İptal' }; %>

  <div class="row g-3">
    <div class="col-md-3 col-sm-6">
      <div class="stat-card text-center">
        <div class="stat-icon">📦</div>
        <div class="stat-value"><%= stats.total_orders %></div>
        <div class="stat-label">Toplam Sipariş</div>
      </div>
    </div>

    <div class="col-md-3 col-sm-6">
      <div class="stat-card text-center">
        <div class="stat-icon">✅</div>
        <div class="stat-value"><%= stats.completed_orders %></div>
        <div class="stat-label">Tamamlanan</div>
      </div>
    </div>

    <div class="col-md-3 col-sm-6">
      <div class="stat-card text-center">
        <div class="stat-icon">💸</div>
        <div class="stat-value">₺<%= Number(stats.total_spent).toFixed(2) %></div>
        <div class="stat-label">Toplam Harcama</div>
      </div>
    </div>

    <div class="col-md-3 col-sm-6">
      <div class="stat-card text-center">
        <div class="stat-icon">📅</div>
        <div class="stat-value" style="font-size: 1.3rem;">
          <% if (stats.last_order_date) { %>
            <%= new Date(stats.last_order_date).toLocaleDateString('tr-TR') %>
          <% } else { %>
            -
          <% } %>
        </div>
        <div class="stat-label">Son Sipariş</div>
      </div>
    </div>
  </div>

  <% if (favoriteCaterer) { %>
    <div class="card shadow-sm border-0 mt-4">
      <div class="card-body p-4">
        <h5 class="mb-1">❤️ En sevdiğin restoran: <%= favoriteCaterer.name %></h5>
        <p class="text-muted mb-0"><%= favoriteCaterer.cnt %> kez sipariş verildi</p>
      </div>
    </div>
  <% } %>

  <div class="mt-4 d-flex justify-content-between align-items-center">
    <h4 class="mb-0">Son Siparişler</h4>
    <a href="/orders" class="small">Tümünü gör →</a>
  </div>

  <% if (!recentOrders || recentOrders.length === 0) { %>
    <div class="empty-state text-center p-5 mt-3">
      <div style="font-size: 2.5rem;">🛒</div>
      <p class="text-muted mb-3">Henüz sipariş yok.</p>
      <a href="/menu" class="btn btn-primary">Menülere göz at</a>
    </div>
  <% } else { %>
    <div class="card shadow-sm border-0 mt-3">
      <div class="table-responsive">
        <table class="table mb-0 align-middle">
          <thead>
            <tr>
              <th>Tarih</th>
              <th>Restoran</th>
              <th>Tutar</th>
              <th>Durum</th>
              <th class="text-end"></th>
            </tr>
          </thead>
          <tbody>
            <% recentOrders.forEach(function(o){ %>
              <tr>
                <td><%= new Date(o.created_at).toLocaleDateString('tr-TR') %></td>
                <td><%= o.caterer_name %></td>
                <td>₺<%= Number(o.total_amount).toFixed(2) %></td>
                <td>
                  <span class="status-badge status-<%= o.status %>">
                    <%= statusLabels[o.status] || o.status %>
                  </span>
                </td>
                <td class="text-end">
                  <a href="/orders/<%= o.id %>/success" class="btn btn-sm btn-outline-secondary">Detay</a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>

  <div class="text-center mt-5">
    <a href="/menu" class="btn btn-primary btn-lg">Yeni Sipariş Ver</a>
  </div>
</div>
