<h2 class="mt-3 mb-3">Ödeme</h2>

<div class="row g-4">
  <!-- sol: form -->
  <div class="col-md-7">
    <div class="checkout-warning">
      <strong>⚠️ Simülasyon</strong> — Bu sayfa bir ödeme simülasyonudur. Gerçek kart bilgisi girmeyin.
      Test için <code>4242 4242 4242 4242</code> kullanabilirsiniz. (0000 ile biten kartlar reddedilir.)
    </div>

    <form action="/cart/checkout" method="POST">
      <div class="card shadow-sm border-0 mb-3">
        <div class="card-body p-4">
          <h5 class="mb-3">Kart Bilgileri</h5>

          <div class="mb-3">
            <label class="form-label">Kart Üzerindeki İsim</label>
            <input type="text" name="card_name" class="form-control" required>
          </div>

          <div class="mb-3">
            <label class="form-label">Kart Numarası</label>
            <input type="text" name="card_number" id="cardNumber" class="form-control"
                   inputmode="numeric" autocomplete="off"
                   placeholder="1234 5678 9012 3456" maxlength="23" required>
          </div>

          <div class="row g-2">
            <div class="col-7">
              <label class="form-label">Son Kullanma</label>
              <input type="text" name="card_expiry" id="cardExpiry" class="form-control"
                     inputmode="numeric" placeholder="MM/YY" maxlength="5" required>
            </div>
            <div class="col-5">
              <label class="form-label">CVV</label>
              <input type="text" name="card_cvv" class="form-control"
                     inputmode="numeric" maxlength="4" required>
            </div>
          </div>
        </div>
      </div>

      <div class="card shadow-sm border-0 mb-3">
        <div class="card-body p-4">
          <h5 class="mb-3">Teslimat Adresi</h5>

          <% if (profileUser && profileUser.address) { %>
            <div class="form-check mb-2">
              <input type="checkbox" name="use_profile_address" id="useProfile"
                     class="form-check-input" checked>
              <label class="form-check-label" for="useProfile">
                Profil adresimi kullan
              </label>
            </div>
            <div class="text-muted small mb-2 ms-4">
              <%= profileUser.address %>
            </div>
          <% } %>

          <textarea name="delivery_address" id="deliveryAddress" class="form-control"
                    rows="2" placeholder="Manuel adres gir"
                    <%= profileUser && profileUser.address ? 'disabled' : '' %>></textarea>
        </div>
      </div>

      <button type="submit" class="btn btn-primary btn-lg w-100">Ödemeyi Onayla</button>
    </form>
  </div>

  <!-- sag: ozet -->
  <div class="col-md-5">
    <div class="checkout-summary">
      <h5 class="mb-3">Sipariş Özeti</h5>
      <% if (caterer) { %>
        <div class="text-muted small mb-2"><%= caterer.name %></div>
      <% } %>

      <% cartItems.forEach(function(ci){ %>
        <div class="checkout-summary-item">
          <div class="d-flex justify-content-between">
            <span><%= ci.quantity %>x <%= ci.menuItem ? ci.menuItem.name : '(silinmiş)' %></span>
            <span>₺<%= ci.subtotal.toFixed(2) %></span>
          </div>
          <% if (ci.options && ci.options.length > 0) { %>
            <div class="small text-muted">
              <em><%= ci.options.map(function(o){ return o.name; }).join(', ') %></em>
            </div>
          <% } %>
          <% if (ci.removals && ci.removals.length > 0) { %>
            <div class="small text-muted">
              <em>Çıkarıldı: <%= ci.removals.map(function(r){ return r.name; }).join(', ') %></em>
            </div>
          <% } %>
        </div>
      <% }) %>

      <div class="d-flex justify-content-between mt-3 pt-3" style="border-top: 1px solid #ddd;">
        <strong>Toplam</strong>
        <strong style="color: var(--primary); font-size: 1.4rem;">₺<%= total.toFixed(2) %></strong>
      </div>

      <a href="/cart" class="d-block text-center mt-3 small">← Sepete geri dön</a>
    </div>
  </div>
</div>

<script src="/js/checkout.js"></script>
