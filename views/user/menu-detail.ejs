<div class="mt-3">
  <a href="/menu" class="small text-muted">&larr; Menülere dön</a>
</div>

<div class="row g-4 mt-1">
  <!-- gorsel -->
  <div class="col-md-6">
    <img src="<%= item.image_path || '/images/no-image.svg' %>"
         alt="<%= item.name %>" class="menu-detail-image">
  </div>

  <!-- bilgi -->
  <div class="col-md-6">
    <h2 class="mb-1"><%= item.name %></h2>
    <div class="text-muted mb-2">
      <%= item.caterer_name %>
      <% if (item.caterer_address) { %>
        <div class="small"><%= item.caterer_address %></div>
      <% } %>
    </div>

    <div class="mb-2">
      <% if (item.menu_avg) {
           var avg = Number(item.menu_avg);
           var full = Math.floor(avg);
           var empty = 5 - full; %>
        <span class="rating-stars">
          <% for (var i = 0; i < full; i++) { %>★<% } %><% for (var j = 0; j < empty; j++) { %>☆<% } %>
        </span>
        <span class="text-muted small ms-1">
          <%= avg.toFixed(1) %> (<%= item.menu_rating_count %> değerlendirme)
        </span>
      <% } else { %>
        <small class="text-muted">Henüz değerlendirilmemiş</small>
      <% } %>
    </div>

    <% if (item.caterer_avg) { %>
      <div class="text-muted small mb-2">
        Restoran ortalaması: <span class="rating-stars">★</span> <%= Number(item.caterer_avg).toFixed(1) %>
      </div>
    <% } %>

    <% if (item.description) { %>
      <p class="mt-3"><%= item.description %></p>
    <% } %>

    <div class="detail-price mt-3">₺<%= Number(item.price).toFixed(2) %></div>

    <!-- restoran konumu -->
    <div class="mt-4">
      <h6 class="mb-2">Restoran Konumu</h6>
      <% if (item.caterer_latitude != null && item.caterer_longitude != null) { %>
        <div id="menuDetailMap"
             style="width: 100%; height: 250px; border-radius: 8px;"
             data-lat="<%= item.caterer_latitude %>"
             data-lng="<%= item.caterer_longitude %>"
             data-name="<%= item.caterer_name %>">
        </div>
      <% } else { %>
        <p class="text-muted small">Konum bilgisi yok.</p>
      <% } %>
    </div>
  </div>
</div>

<!-- siparis ozellestirme -->
<div class="mt-5">
  <h4 class="mb-3">Siparişini Özelleştir</h4>

  <form id="orderForm" action="/cart/add" method="POST" data-base-price="<%= item.price %>">
    <input type="hidden" name="menu_item_id" value="<%= item.id %>">

    <!-- option groups -->
    <% groups.forEach(function(g){ %>
      <div class="option-section">
        <div class="d-flex justify-content-between align-items-center mb-2">
          <div>
            <strong><%= g.name %></strong>
            <% if (g.is_required) { %>
              <span class="badge bg-warning text-dark ms-1">Zorunlu</span>
            <% } %>
          </div>
          <small class="text-muted">
            <% if (g.max_select > 1) { %>
              en az <%= g.min_select %>, en fazla <%= g.max_select %> seçim
            <% } else { %>
              <%= g.is_required ? 'bir seçim yap' : 'opsiyonel' %>
            <% } %>
          </small>
        </div>

        <% g.options.forEach(function(o){ %>
          <div class="option-row">
            <label class="form-check-label d-flex align-items-center gap-2 mb-0 w-100">
              <% if (g.max_select === 1) { %>
                <input type="radio" class="form-check-input"
                       name="options_<%= g.id %>" value="<%= o.id %>"
                       data-extra-price="<%= o.extra_price %>"
                       data-group="<%= g.id %>"
                       <%= g.is_required ? 'required' : '' %>>
              <% } else { %>
                <input type="checkbox" class="form-check-input"
                       name="options[]" value="<%= o.id %>"
                       data-extra-price="<%= o.extra_price %>"
                       data-group="<%= g.id %>"
                       data-max="<%= g.max_select %>">
              <% } %>
              <span class="flex-grow-1"><%= o.name %></span>
              <span class="option-extra">
                <% if (Number(o.extra_price) > 0) { %>
                  +₺<%= Number(o.extra_price).toFixed(2) %>
                <% } else { %>
                  Ücretsiz
                <% } %>
              </span>
            </label>
          </div>
        <% }) %>
      </div>
    <% }) %>

    <!-- removables -->
    <% if (removables && removables.length > 0) { %>
      <div class="option-section">
        <div class="mb-2">
          <strong>Çıkarmak istediklerini seç</strong>
        </div>
        <% removables.forEach(function(r){ %>
          <div class="option-row">
            <label class="form-check-label d-flex align-items-center gap-2 mb-0 w-100">
              <input type="checkbox" class="form-check-input"
                     name="removals[]" value="<%= r.id %>">
              <span><%= r.name %></span>
            </label>
          </div>
        <% }) %>
      </div>
    <% } %>

    <!-- adet -->
    <div class="option-section">
      <div class="d-flex align-items-center justify-content-between">
        <strong>Adet</strong>
        <div class="qty-controls">
          <button type="button" class="qty-btn" id="qtyMinus">-</button>
          <input type="number" name="quantity" id="quantity" class="form-control text-center"
                 min="1" max="20" value="1" style="width: 70px;">
          <button type="button" class="qty-btn" id="qtyPlus">+</button>
        </div>
      </div>
    </div>

    <div class="total-display">
      Toplam: ₺<span id="totalPrice">0.00</span>
    </div>

    <button type="submit" class="btn btn-primary btn-lg w-100">Sepete Ekle</button>
  </form>
</div>

<!-- yorumlar -->
<div class="mt-5">
  <h4 class="mb-3">Son Yorumlar</h4>
  <% if (!recentComments || recentComments.length === 0) { %>
    <p class="text-muted">Henüz yorum yok.</p>
  <% } else { %>
    <% recentComments.forEach(function(c){ %>
      <div class="comment-card">
        <div class="d-flex justify-content-between align-items-center">
          <strong><%= c.user_name %></strong>
          <span class="comment-meta">
            <%= new Date(c.created_at).toLocaleDateString('tr-TR') %>
          </span>
        </div>
        <div class="rating-stars">
          <% for (var i = 0; i < (c.menu_rating || 0); i++) { %>★<% } %><% for (var j = (c.menu_rating || 0); j < 5; j++) { %>☆<% } %>
        </div>
        <div class="mt-1"><%= c.comment %></div>
      </div>
    <% }) %>
  <% } %>
</div>

<script src="/js/menu-detail.js"></script>
