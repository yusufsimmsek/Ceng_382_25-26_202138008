<h2 class="mt-3 mb-3">Siparişini Değerlendir</h2>

<div class="card shadow-sm border-0 mb-3">
  <div class="card-body p-4">
    <h6 class="text-muted mb-2">Sipariş #<%= order.id %></h6>
    <div class="small mb-2">
      <%= new Date(order.created_at).toLocaleDateString('tr-TR') %> -
      <strong><%= order.caterer_name %></strong>
    </div>
    <ul class="mb-0 small text-muted">
      <% items.forEach(function(it){ %>
        <li><%= it.quantity %>x <%= it.menu_name || '(silinmiş)' %></li>
      <% }) %>
    </ul>
  </div>
</div>

<form action="/orders/<%= order.id %>/rate" method="POST" class="card shadow-sm border-0">
  <div class="card-body p-4">

    <div class="rating-section">
      <h5>Yemek nasıldı?</h5>
      <div class="star-rating" data-target="menu_rating">
        <span class="star" data-value="1">★</span>
        <span class="star" data-value="2">★</span>
        <span class="star" data-value="3">★</span>
        <span class="star" data-value="4">★</span>
        <span class="star" data-value="5">★</span>
      </div>
      <input type="hidden" name="menu_rating" value="">
      <span class="rating-label"></span>
    </div>

    <div class="rating-section">
      <h5>Restoranı genel olarak nasıl buldun?</h5>
      <div class="star-rating" data-target="caterer_rating">
        <span class="star" data-value="1">★</span>
        <span class="star" data-value="2">★</span>
        <span class="star" data-value="3">★</span>
        <span class="star" data-value="4">★</span>
        <span class="star" data-value="5">★</span>
      </div>
      <input type="hidden" name="caterer_rating" value="">
      <span class="rating-label"></span>
    </div>

    <div class="mb-3 mt-3">
      <label for="comment" class="form-label">Yorumun (isteğe bağlı)</label>
      <textarea name="comment" id="comment" class="form-control" rows="3"
                maxlength="500" placeholder="Deneyimini paylaş (max 500 karakter)"></textarea>
    </div>

    <div class="d-flex gap-2 mt-4">
      <button type="submit" class="btn btn-primary">Değerlendirmeyi Gönder</button>
      <a href="/orders" class="btn btn-outline-secondary">İptal</a>
    </div>
  </div>
</form>

<script src="/js/rating.js"></script>
