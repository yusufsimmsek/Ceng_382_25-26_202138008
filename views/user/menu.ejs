<h2 class="mt-3 mb-3">Menüler</h2>

<!-- konum bannerlari (sadece user rolu icin) -->
<% if (isUserRole) { %>
  <% if (!locationAvailable) { %>
    <div class="location-banner-warn d-flex justify-content-between align-items-center flex-wrap gap-2">
      <span>📍 Yakındaki restoranları görmek için konumunu belirle.</span>
      <button id="locateBtn" type="button" class="btn btn-sm btn-primary">Konumumu Belirle</button>
    </div>
    <form id="locationForm" action="/user/profile/location" method="POST" class="d-none">
      <input type="hidden" name="lat" id="latInput">
      <input type="hidden" name="lng" id="lngInput">
      <input type="hidden" name="redirect" value="/menu">
    </form>
    <script>
      document.getElementById('locateBtn').addEventListener('click', function() {
        if (!navigator.geolocation) { alert('Tarayıcın konum desteklemiyor'); return; }
        this.textContent = 'Konum alınıyor...';
        var self = this;
        navigator.geolocation.getCurrentPosition(
          function(pos) {
            document.getElementById('latInput').value = pos.coords.latitude;
            document.getElementById('lngInput').value = pos.coords.longitude;
            document.getElementById('locationForm').submit();
          },
          function(err) {
            self.textContent = 'Konumumu Belirle';
            alert('Konum alınamadı: ' + err.message);
          }
        );
      });
    </script>
  <% } else { %>
    <div class="location-banner-ok d-flex justify-content-between align-items-center flex-wrap gap-2">
      <span>📍 Konumun belirli — yakındaki restoranlar gösteriliyor.</span>
      <a href="/user/profile" class="small">Konumu güncelle</a>
    </div>
  <% } %>
<% } %>

<!-- filtre bar -->
<div class="filter-bar">
  <form method="GET" action="/menu" class="row g-2 align-items-end">
    <div class="col-md-4">
      <label class="form-label small">Restoran</label>
      <select name="caterer" class="form-select">
        <option value="">Tümü</option>
        <% caterers.forEach(function(c){ %>
          <option value="<%= c.id %>" <%= String(filters.caterer) === String(c.id) ? 'selected' : '' %>>
            <%= c.name %>
          </option>
        <% }) %>
      </select>
    </div>
    <div class="col-md-2">
      <label class="form-label small">Min Fiyat</label>
      <input type="number" name="minPrice" class="form-control" step="0.01" min="0"
             value="<%= filters.minPrice %>">
    </div>
    <div class="col-md-2">
      <label class="form-label small">Max Fiyat</label>
      <input type="number" name="maxPrice" class="form-control" step="0.01" min="0"
             value="<%= filters.maxPrice %>">
    </div>
    <% if (locationAvailable) { %>
      <div class="col-md-2">
        <label class="form-label small">Yarıçap</label>
        <select name="radius" class="form-select">
          <% [5, 10, 20, 50].forEach(function(r){ %>
            <option value="<%= r %>" <%= String(filters.radius) === String(r) ? 'selected' : '' %>>
              <%= r %> km
            </option>
          <% }) %>
        </select>
      </div>
    <% } %>
    <div class="col-md-<%= locationAvailable ? 2 : 4 %> d-flex gap-2">
      <button type="submit" class="btn btn-primary">Filtrele</button>
      <a href="/menu" class="btn btn-outline-secondary">Temizle</a>
    </div>
  </form>
</div>

<% if (!items || items.length === 0) { %>
  <div class="empty-state text-center p-5">
    <div style="font-size: 2.5rem;">🔎</div>
    <% if (locationAvailable) { %>
      <p class="text-muted mb-0">Bu mesafede restoran yok. Yarıçapı artırmayı dene.</p>
    <% } else { %>
      <p class="text-muted mb-0">Bu kriterlere uygun menü yok.</p>
    <% } %>
  </div>
<% } else { %>
  <div class="row g-3">
    <% items.forEach(function(it){ %>
      <div class="col-md-4 col-lg-3">
        <div class="card menu-card h-100">
          <img src="<%= it.image_path || '/images/no-image.svg' %>" alt="<%= it.name %>">
          <div class="card-body d-flex flex-column">
            <h5 class="mb-1"><%= it.name %></h5>
            <div class="price">₺<%= Number(it.price).toFixed(2) %></div>
            <div class="caterer-name mb-2">
              <%= it.caterer_name %>
              <% if (locationAvailable && catererDistances[it.caterer_id] != null) { %>
                <span class="distance-badge ms-1">📍 <%= catererDistances[it.caterer_id].toFixed(1) %> km</span>
              <% } %>
            </div>

            <div class="rating-line mb-1">
              <% if (it.menu_avg) {
                   var avg = Number(it.menu_avg);
                   var full = Math.floor(avg);
                   var empty = 5 - full; %>
                <span class="rating-stars">
                  <% for (var i = 0; i < full; i++) { %>★<% } %><% for (var j = 0; j < empty; j++) { %>☆<% } %>
                </span>
                <small class="text-muted ms-1">
                  <%= avg.toFixed(1) %> (<%= it.menu_rating_count %>)
                </small>
              <% } else { %>
                <small class="text-muted">Henüz değerlendirme yok</small>
              <% } %>
            </div>

            <% if (it.caterer_avg) { %>
              <small class="text-muted d-block mb-2">
                Restoran: <span class="rating-stars">★</span> <%= Number(it.caterer_avg).toFixed(1) %>
              </small>
            <% } %>

            <p class="text-muted small mb-3" style="min-height: 36px;">
              <% if (it.description) { %>
                <%= it.description.length > 80 ? it.description.substring(0, 80) + '...' : it.description %>
              <% } %>
            </p>

            <a href="/menu/<%= it.id %>" class="btn btn-primary mt-auto w-100">Detay</a>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>
