@page
@model Lab3.Pages.IndexModel
@{
    ViewData["Title"] = "Home";
}



@if (!string.IsNullOrWhiteSpace(Model.DatabaseErrorMessage))
{
    <div class="alert alert-warning" role="alert">
        @Model.DatabaseErrorMessage
    </div>
}

<div class="card shadow-sm mb-4">
    <div class="card-header bg-white">
        <h5 class="mb-0">1. Registered Users</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 120px;">Photo</th>
                        <th>User Name</th>
                        <th>Email</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Users.Count == 0)
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted py-4">No users found.</td>
                    </tr>
                }
                else
                {
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(user.ProfilePhotoDataUrl))
                                {
                                    <img src="@user.ProfilePhotoDataUrl" alt="Profile" class="rounded-circle user-thumb" />
                                }
                                else
                                {
                                    <span class="badge text-bg-secondary">No Photo</span>
                                }
                            </td>
                            <td>@user.UserName</td>
                            <td>@user.Email</td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-white">
        <h5 class="mb-0">2. Java script method (folder gallery)</h5>
    </div>
    <div class="card-body">
        <form method="post" asp-page-handler="UploadImage" enctype="multipart/form-data" class="row g-3 align-items-end mb-3">
            <div class="col-md-9">
                <label asp-for="GalleryFile" class="form-label">Select Image</label>
                <input asp-for="GalleryFile" type="file" class="form-control" id="galleryFile" accept="image/*" />
            </div>
            <div class="col-md-3 d-grid">
                <button type="submit" class="btn btn-primary">Upload to Database</button>
            </div>
        </form>

        <div id="previewWrapper" class="mb-3 d-none">
            <div class="small text-muted mb-2">Client-side preview (not saved yet):</div>
            <img id="previewImage" class="img-fluid rounded border" alt="Preview" style="max-height: 220px;" />
        </div>

        <div class="row g-3">
        @if (Model.GalleryImages.Count == 0)
        {
            <div class="col-12">
                <div class="text-muted">No images saved yet.</div>
            </div>
        }
        else
        {
            @foreach (var image in Model.GalleryImages)
            {
                <div class="col-sm-6 col-lg-3">
                    <div class="border rounded p-2 h-100 bg-light-subtle">
                        <img src="@image.DataUrl" alt="@image.FileName" class="img-fluid rounded gallery-thumb mb-2" />
                        <div class="small fw-semibold text-truncate">@image.FileName</div>
                        <div class="small text-muted">@Math.Round(image.Size / 1024.0, 2) KB</div>
                    </div>
                </div>
            }
        }
        </div>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-white">
        <h5 class="mb-0">3. C# method carousel</h5>
    </div>
    <div class="card-body">
        <form method="post" asp-page-handler="UploadCarouselImage" enctype="multipart/form-data" class="row g-3 align-items-end mb-3">
            <div class="col-md-9">
                <label asp-for="CarouselFile" class="form-label">Dosya Seç (Carousel)</label>
                <input asp-for="CarouselFile" type="file" class="form-control" id="carouselFile" accept="image/*" />
            </div>
            <div class="col-md-3 d-grid">
                <button type="submit" class="btn btn-outline-primary">Carousel'e Yükle</button>
            </div>
        </form>

    @if (Model.CarouselImages.Count == 0)
    {
        <div class="text-muted">No images available for carousel.</div>
    }
    else
    {
        <div id="csharpGalleryCarousel" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-inner rounded">
            @for (var i = 0; i < Model.CarouselImages.Count; i++)
            {
                var image = Model.CarouselImages[i];
                <div class="carousel-item @(i == 0 ? "active" : "")">
                    <img src="@image.DataUrl" class="d-block w-100 carousel-image" alt="@image.FileName" />
                    <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded px-2 py-1">
                        <div class="small fw-semibold text-truncate">@image.FileName</div>
                        <div class="small">@Math.Round(image.Size / 1024.0, 2) KB</div>
                    </div>
                </div>
            }
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#csharpGalleryCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#csharpGalleryCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Next</span>
            </button>
        </div>
    }
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var fileInput = document.getElementById("galleryFile");
            var previewWrapper = document.getElementById("previewWrapper");
            var previewImage = document.getElementById("previewImage");

            if (!fileInput || !previewWrapper || !previewImage) {
                return;
            }

            fileInput.addEventListener("change", function (event) {
                var target = event.target;
                var file = target.files && target.files[0];
                if (!file) {
                    previewWrapper.classList.add("d-none");
                    previewImage.removeAttribute("src");
                    return;
                }

                var reader = new FileReader();
                reader.onload = function (e) {
                    previewImage.src = String(e.target.result);
                    previewWrapper.classList.remove("d-none");
                };
                reader.readAsDataURL(file);
            });
        })();
    </script>
}
