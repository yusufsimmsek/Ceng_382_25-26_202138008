<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Lab3</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Lab3.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-gradient border-0 shadow-sm">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="brand-icon me-2">�</span>
                    <span>DASHBOARD</span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 ms-auto">
                        <li class="nav-item">
                            <a class="nav-link text-white fw-500 nav-link-hover" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="me-1">🏠</i> Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white fw-500 nav-link-hover" asp-area="" asp-controller="Home" asp-action="Privacy">
                                <i class="me-1">🔒</i> Privacy
                            </a>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="main-content">
        <div class="container-fluid">
            <main role="main" class="py-4">
                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="footer-gradient text-white mt-auto">
        <div class="container-fluid">
            <div class="row py-4">
                <div class="col-md-6">
                    <h5 class="fw-bold mb-3">� DASHBOARD</h5>
                    <p class="text-white-50">Professional image management and carousel system built with ASP.NET Core</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <p class="text-white-50 mb-1">&copy; 2026 - DASHBOARD</p>
                    <a asp-area="" asp-controller="Home" asp-action="Privacy" class="link-light text-decoration-none">Privacy Policy</a>
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
