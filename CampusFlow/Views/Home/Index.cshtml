@{
    ViewData["Title"] = "Overview";
}

<section class="hero-stage">
    <div class="hero-panel hero-primary">
        <span class="eyebrow">Project identity</span>
        <h2>Campus events, club activity and student engagement in one intelligent flow.</h2>
        <p class="hero-lead">
            CampusFlow turns scattered university announcements into a focused platform where clubs publish
            events, students join activities, and participation becomes measurable through a lightweight
            engagement score.
        </p>

        <div class="hero-actions">
            <a class="btn btn-primary" asp-controller="Events" asp-action="Index">Browse events</a>
            <a class="btn btn-outline-light" asp-controller="Dashboard" asp-action="Index">Open dashboard</a>
        </div>

        <div class="hero-ribbon">
            <div>
                <strong>Role-based flow</strong>
                <span>Student and Club Administrator journeys</span>
            </div>
            <div>
                <strong>Relational core</strong>
                <span>Users, Clubs, Events, UserEvents</span>
            </div>
        </div>
    </div>

    <div class="hero-panel hero-secondary">
        <div class="hero-card-header">
            <span class="eyebrow">Live concept board</span>
            <span class="chip chip-muted">Week 1</span>
        </div>

        <div class="signal-stack">
            <article>
                <strong>Discover</strong>
                <p>Students scan upcoming events through a clean central feed instead of fragmented channels.</p>
            </article>
            <article>
                <strong>Join</strong>
                <p>Participation becomes an action recorded in the system, not just a vague RSVP idea.</p>
            </article>
            <article>
                <strong>Measure</strong>
                <p>Simple engagement scoring creates a stronger and more original project narrative.</p>
            </article>
        </div>
    </div>
</section>

<section class="insight-band">
    <article class="insight-tile">
        <span class="metric">2</span>
        <h3>Core roles</h3>
        <p>Student and Club Administrator are enough to establish the first authorization story.</p>
    </article>
    <article class="insight-tile">
        <span class="metric">4</span>
        <h3>Main entities</h3>
        <p>The database already has a clear relational backbone for future CRUD and statistics.</p>
    </article>
    <article class="insight-tile">
        <span class="metric">10x</span>
        <h3>Engagement rule</h3>
        <p>Every joined event adds ten points to the participation-driven scoring idea.</p>
    </article>
    <article class="insight-tile">
        <span class="metric">1</span>
        <h3>Unified platform</h3>
        <p>Clubs, events and students meet in one consistent interface instead of separate tools.</p>
    </article>
</section>

<section class="editorial-grid">
    <article class="panel-card feature-panel">
        <div class="panel-head">
            <span class="eyebrow">For students</span>
            <h3>One place to follow campus life</h3>
        </div>
        <p class="muted-copy">
            Students can quickly see what is happening on campus, explore different categories and join
            activities without chasing announcements across multiple channels.
        </p>
        <ul class="feature-list">
            <li>Upcoming events collected in one screen</li>
            <li>Cleaner event details and organizer visibility</li>
            <li>Easy participation flow for student activities</li>
            <li>Consistent interface across clubs and events</li>
        </ul>
    </article>

    <article class="panel-card architecture-panel">
        <div class="panel-head">
            <span class="eyebrow">For clubs</span>
            <h3>A clearer way to reach the right audience</h3>
        </div>
        <div class="layer-list">
            <div>
                <strong>Event publishing</strong>
                <p>Clubs can present workshops, talks and social events in a clear and organized way.</p>
            </div>
            <div>
                <strong>Club visibility</strong>
                <p>Each organizer can have a recognizable presence instead of disappearing in scattered posts.</p>
            </div>
            <div>
                <strong>Participation overview</strong>
                <p>Clubs can better understand how students interact with activities over time.</p>
            </div>
        </div>
    </article>
</section>

<section class="showcase-grid">
    <article class="showcase-card">
        <span class="eyebrow">Categories</span>
        <h3>Different event types in one flow</h3>
        <div class="timeline">
            <div>
                <strong>Technology</strong>
                <p>Talks, hackathons and innovation-focused student sessions.</p>
            </div>
            <div>
                <strong>Career</strong>
                <p>Interview practice, CV reviews, alumni meetings and internship events.</p>
            </div>
            <div>
                <strong>Culture</strong>
                <p>Film nights, community gatherings and social activities across campus.</p>
            </div>
        </div>
    </article>

    <article class="showcase-card accent-card">
        <span class="eyebrow">Platform goals</span>
        <h3>What CampusFlow aims to improve</h3>
        <ul class="feature-list">
            <li>Reduce missed announcements</li>
            <li>Make events easier to discover</li>
            <li>Help clubs communicate with students</li>
            <li>Encourage more active campus participation</li>
        </ul>
    </article>
</section>
