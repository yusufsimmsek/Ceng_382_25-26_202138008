@{
    ViewData["Title"] = "About";
}

<section class="page-hero compact-hero">
    <div>
        <span class="eyebrow">About CampusFlow</span>
        <h2>A smarter way to organize campus events.</h2>
        <p class="muted-copy">
            CampusFlow brings student clubs, upcoming activities and campus participation together in one
            accessible platform.
        </p>
    </div>
</section>

<section class="card-grid">
    <article class="panel-card">
        <span class="eyebrow">Students</span>
        <h3>Follow upcoming activities and join events from one central place.</h3>
    </article>
    <article class="panel-card">
        <span class="eyebrow">Clubs</span>
        <h3>Share events with better visibility and keep announcements organized.</h3>
    </article>
    <article class="panel-card accent-card">
        <span class="eyebrow">Campus</span>
        <h3>Support a more connected and active university community.</h3>
    </article>
</section>
