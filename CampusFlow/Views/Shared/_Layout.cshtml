@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;

    string NavClass(string controller) =>
        currentController.Equals(controller, StringComparison.OrdinalIgnoreCase) ? "is-active" : string.Empty;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CampusFlow</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CampusFlow.styles.css" asp-append-version="true" />
</head>
<body class="app-body">
    <div class="ambient ambient-one"></div>
    <div class="ambient ambient-two"></div>
    <div class="ambient ambient-grid"></div>

    <div class="app-shell">
        <aside class="sidebar" id="sidebar">
            <a class="brand" asp-area="" asp-controller="Home" asp-action="Index">
                <span class="brand-mark">CF</span>
                <span class="brand-copy">
                    <strong>CampusFlow</strong>
                    <small>Smart Campus Event Platform</small>
                </span>
            </a>

            <div class="sidebar-section">
                <span class="sidebar-label">Navigation</span>
                <nav class="sidebar-nav">
                    <a class="@NavClass("Home")" asp-controller="Home" asp-action="Index">
                        <span>Overview</span>
                        <small>Landing</small>
                    </a>
                    <a class="@NavClass("Events")" asp-controller="Events" asp-action="Index">
                        <span>Events</span>
                        <small>Schedule</small>
                    </a>
                    <a class="@NavClass("Clubs")" asp-controller="Clubs" asp-action="Index">
                        <span>Clubs</span>
                        <small>Organizers</small>
                    </a>
                    <a class="@NavClass("Dashboard")" asp-controller="Dashboard" asp-action="Index">
                        <span>Dashboard</span>
                        <small>Metrics</small>
                    </a>
                </nav>
            </div>

            <div class="sidebar-card">
                <span class="eyebrow">CampusFlow</span>
                <h6>Campus at a glance</h6>
                <p>Discover activities, follow student clubs and keep campus life in one organized place.</p>
                <div class="mini-stack">
                    <span>Events</span>
                    <span>Clubs</span>
                    <span>Participation</span>
                </div>
            </div>
        </aside>

        <div class="page-frame">
            <header class="topbar">
                <div class="topbar-copy">
                    <p class="eyebrow">CENG 382 term project</p>
                    <h1>@(ViewData["Title"] ?? "CampusFlow")</h1>
                </div>

                <div class="topbar-actions">
                    <div class="topbar-status">
                        <span class="status-dot"></span>
                        <span>Live campus feed</span>
                    </div>
                    <a class="ghost-link" asp-controller="Events" asp-action="Index">Browse events</a>
                    <button class="sidebar-toggle" id="sidebarToggle" type="button">Menu</button>
                </div>
            </header>

            <main role="main" class="main-content">
                @RenderBody()
            </main>

            <footer class="footer">
                <div class="footer-block">
                    <strong>CampusFlow</strong>
                    <span>Campus events and student communities on one platform.</span>
                </div>
                <div class="footer-block footer-links">
                    <a asp-controller="Events" asp-action="Index">Events</a>
                    <a asp-controller="Clubs" asp-action="Index">Clubs</a>
                </div>
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
