@{
    ViewData["Title"] = "Clubs";
}

<section class="page-hero compact-hero">
    <div>
        <span class="eyebrow">Club directory</span>
        <h2>Organizers that shape the campus experience.</h2>
        <p class="muted-copy">
            Clubs own events, publish announcements and become the operational side of the platform.
        </p>
    </div>
    <a class="btn btn-primary" href="#">Add club</a>
</section>

<section class="showcase-grid">
    <article class="showcase-card">
        <span class="eyebrow">Innovation Club</span>
        <h3>Technology, entrepreneurship and design-driven experiences.</h3>
        <p class="muted-copy">
            This club profile can later display event history, organizer metrics and active members.
        </p>
    </article>

    <article class="showcase-card">
        <span class="eyebrow">Career Society</span>
        <h3>Workshops, alumni meetings and practical preparation for internships.</h3>
        <p class="muted-copy">
            Club pages naturally connect with event cards through the one-to-many relationship in the data model.
        </p>
    </article>

    <article class="showcase-card accent-card">
        <span class="eyebrow">Platform role</span>
        <h3>Every club becomes a reliable organizer identity.</h3>
        <ul class="feature-list">
            <li>Publishes event cards</li>
            <li>Reaches the right student audience</li>
            <li>Builds a measurable participation history</li>
        </ul>
    </article>
</section>
