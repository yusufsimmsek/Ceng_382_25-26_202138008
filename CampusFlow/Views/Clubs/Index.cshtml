@{
    ViewData["Title"] = "Clubs";
}

<section class="page-section">
    <div class="section-heading">
        <div>
            <span class="eyebrow">Club directory</span>
            <h2>Organizers inside the CampusFlow ecosystem</h2>
        </div>
        <a class="btn btn-outline-light" href="#">Add Club</a>
    </div>

    <div class="card-grid">
        <article class="panel-card">
            <span class="eyebrow">Innovation Club</span>
            <h3>Builds events around technology, entrepreneurship and design thinking.</h3>
            <p>Each club will own events through a one-to-many relationship in the database model.</p>
        </article>

        <article class="panel-card">
            <span class="eyebrow">Career Society</span>
            <h3>Focuses on workshops, alumni meetings and internship preparation sessions.</h3>
            <p>Club detail pages can later show announcements, event lists and engagement metrics.</p>
        </article>
    </div>
</section>
