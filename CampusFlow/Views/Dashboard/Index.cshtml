@{
    ViewData["Title"] = "Dashboard";
}

<section class="page-hero compact-hero">
    <div>
        <span class="eyebrow">Analytics preview</span>
        <h2>The layer that makes CampusFlow feel original.</h2>
        <p class="muted-copy">
            Participation numbers, active students and popular events eventually converge here as a live campus pulse.
        </p>
    </div>
</section>

<section class="insight-band">
    <article class="insight-tile">
        <span class="metric">128</span>
        <h3>Total joins</h3>
        <p>Participation records will come from the UserEvents join table.</p>
    </article>
    <article class="insight-tile">
        <span class="metric">34</span>
        <h3>Active students</h3>
        <p>The score model helps surface the most engaged users on campus.</p>
    </article>
    <article class="insight-tile">
        <span class="metric">9</span>
        <h3>Club organizers</h3>
        <p>Role-based visibility makes club contributions measurable as well.</p>
    </article>
    <article class="insight-tile">
        <span class="metric">87%</span>
        <h3>Event reach</h3>
        <p>A future metric area for attendance quality and platform usage trends.</p>
    </article>
</section>

<section class="editorial-grid">
    <article class="panel-card">
        <div class="panel-head">
            <span class="eyebrow">Most active students</span>
            <h3>Leaderboard-ready dashboard block</h3>
        </div>
        <div class="layer-list">
            <div>
                <strong>Aylin K.</strong>
                <p>Joined 12 events and leads the current engagement sample.</p>
            </div>
            <div>
                <strong>Berat T.</strong>
                <p>Strong activity across innovation and career categories.</p>
            </div>
            <div>
                <strong>Ece Y.</strong>
                <p>High consistency in club sessions and workshop attendance.</p>
            </div>
        </div>
    </article>

    <article class="panel-card accent-card">
        <div class="panel-head">
            <span class="eyebrow">Value</span>
            <h3>Why this dashboard matters</h3>
        </div>
        <p class="muted-copy">
            The dashboard turns CampusFlow from a standard listing tool into a participation-aware platform
            with clearer feedback for both students and club administrators.
        </p>
    </article>
</section>
