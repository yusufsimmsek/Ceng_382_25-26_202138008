@{
    ViewData["Title"] = "Dashboard";
}

<section class="page-section">
    <div class="section-heading">
        <div>
            <span class="eyebrow">Analytics preview</span>
            <h2>Starter dashboard blocks for future statistics</h2>
        </div>
    </div>

    <div class="stats-grid">
        <article class="info-card">
            <span class="metric">128</span>
            <h3>Total joins</h3>
            <p>Participation counts will later come from the UserEvents table.</p>
        </article>
        <article class="info-card">
            <span class="metric">34</span>
            <h3>Active students</h3>
            <p>This block will surface the students with the highest engagement score.</p>
        </article>
        <article class="info-card">
            <span class="metric">9</span>
            <h3>Club organizers</h3>
            <p>Role-based metrics fit naturally into the dashboard area.</p>
        </article>
    </div>

    <article class="panel-card">
        <div class="panel-head">
            <span class="eyebrow">Why this matters</span>
            <h3>CampusFlow is more than a basic event list</h3>
        </div>
        <p class="muted-copy">
            The dashboard layer is where event visibility, participation tracking and engagement scoring
            come together as a more original course project.
        </p>
    </article>
</section>
