@{
    ViewData["Title"] = "Events";
}

<section class="page-section">
    <div class="section-heading">
        <div>
            <span class="eyebrow">Event management</span>
            <h2>Upcoming campus activity structure</h2>
        </div>
        <a class="btn btn-outline-light" href="#">Create Event</a>
    </div>

    <div class="card-grid">
        <article class="event-card">
            <span class="chip">Technology</span>
            <h3>AI for Student Communities</h3>
            <p>A sample event card for future CRUD operations and participation tracking.</p>
            <div class="event-meta">
                <span>22 Apr 2026</span>
                <span>Innovation Club</span>
            </div>
        </article>

        <article class="event-card">
            <span class="chip">Career</span>
            <h3>CV Review and Mock Interview</h3>
            <p>Students will later join events from this page and build measurable activity history.</p>
            <div class="event-meta">
                <span>25 Apr 2026</span>
                <span>Career Society</span>
            </div>
        </article>

        <article class="event-card">
            <span class="chip">Culture</span>
            <h3>Spring Film Night</h3>
            <p>Cards give the UI a modern showcase for category, date and organizer data.</p>
            <div class="event-meta">
                <span>29 Apr 2026</span>
                <span>Cinema Club</span>
            </div>
        </article>
    </div>
</section>
