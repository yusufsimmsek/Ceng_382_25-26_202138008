@{
    ViewData["Title"] = "Events";
}

<section class="page-hero compact-hero">
    <div>
        <span class="eyebrow">Event management</span>
        <h2>Upcoming campus moments designed for discovery.</h2>
        <p class="muted-copy">
            This page is the future home of searchable event cards, participation actions and club-owned schedules.
        </p>
    </div>
    <a class="btn btn-primary" href="#">Create event</a>
</section>

<section class="featured-strip">
    <article class="featured-event">
        <span class="chip">Featured event</span>
        <h3>Campus Innovation Summit</h3>
        <p>
            A headline event card can highlight the most important weekly activity while still showing
            category, organizer and participation context.
        </p>
        <div class="event-meta">
            <span>30 Apr 2026</span>
            <span>Innovation Club</span>
            <span>Main Hall</span>
        </div>
    </article>

    <div class="schedule-column">
        <div>
            <strong>Tue</strong>
            <span>Mock interview session</span>
        </div>
        <div>
            <strong>Thu</strong>
            <span>Startup idea workshop</span>
        </div>
        <div>
            <strong>Sat</strong>
            <span>Film night and open discussion</span>
        </div>
    </div>
</section>

<section class="card-grid">
    <article class="event-card">
        <span class="chip">Technology</span>
        <h3>AI for Student Communities</h3>
        <p>A category-driven card for future CRUD operations and measurable participation tracking.</p>
        <div class="event-meta">
            <span>22 Apr 2026</span>
            <span>Innovation Club</span>
        </div>
    </article>

    <article class="event-card">
        <span class="chip">Career</span>
        <h3>CV Review and Mock Interview</h3>
        <p>Students will later join events from this page and build a visible activity history.</p>
        <div class="event-meta">
            <span>25 Apr 2026</span>
            <span>Career Society</span>
        </div>
    </article>

    <article class="event-card">
        <span class="chip">Culture</span>
        <h3>Spring Film Night</h3>
        <p>Cards bring category, date and organizer data into a cleaner, more premium interface.</p>
        <div class="event-meta">
            <span>29 Apr 2026</span>
            <span>Cinema Club</span>
        </div>
    </article>
</section>
